# Database
DATABASE_URL="postgresql://sms_user:sms_password@localhost:5432/sms_db?schema=public"

# NextAuth
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Redis (required for background jobs: SMS, email, bulk operations)
REDIS_URL="redis://localhost:6379"

# Cloudflare R2 Storage (required for file uploads/documents)
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="sms-uploads"

# SMS Gateway
SMS_PROVIDER="hubtel"
SMS_API_KEY=""
SMS_API_SECRET=""
SMS_SENDER_ID="SMS"

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# Email SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@school.edu.gh"
