model Student {
  id                       String         @id @default(cuid())
  schoolId                 String
  studentId                String         @unique // Auto-generated: SCH/YYYY/NNNN
  userId                   String?        @unique // Optional link to User for portal access
  firstName                String
  lastName                 String
  otherNames               String?
  dateOfBirth              DateTime
  gender                   Gender
  nationality              String?        @default("Ghanaian")
  hometown                 String?
  region                   String?
  religion                 String?
  bloodGroup               String?
  medicalConditions        String?
  allergies                String?
  photoUrl                 String?
  boardingStatus           BoardingStatus @default(DAY)
  status                   StudentStatus  @default(ACTIVE)
  enrollmentDate           DateTime       @default(now())
  idCardPdfKey             String?
  idCardCachedAt           DateTime?
  idCardCacheInvalidatedAt DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  guardians       StudentGuardian[]
  enrollments     Enrollment[]
  houseAssignment StudentHouse?
  medicalRecords  MedicalRecord[]

  promotionRunItems PromotionRunItem[]

  studentDocuments StudentDocument[]

  reportCardPdfCaches ReportCardPdfCache[]

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([firstName, lastName])
  @@index([schoolId, status])
  @@index([schoolId, gender, status])
  @@index([schoolId, boardingStatus, status])
  @@index([schoolId, region, status])
  @@index([schoolId, religion, status])
  @@index([householdId])
}

model Guardian {
  id           String   @id @default(cuid())
  schoolId     String
  userId       String?  @unique // Optional link to User for parent portal
  firstName    String
  lastName     String
  phone        String
  altPhone     String?
  email        String?
  occupation   String?
  address      String?
  relationship String? // e.g., Father, Mother, Uncle, Guardian
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students    StudentGuardian[]
  school      School            @relation("SchoolGuardian", fields: [schoolId], references: [id])
  householdId String?
  household   Household?        @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([firstName, lastName])
  @@index([schoolId])
  @@index([householdId])
}

model StudentGuardian {
  id         String  @id @default(cuid())
  studentId  String
  guardianId String
  schoolId   String
  isPrimary  Boolean @default(false)

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  school   School   @relation("SchoolStudentGuardian", fields: [schoolId], references: [id])

  @@unique([studentId, guardianId])
  @@index([guardianId])
  @@index([schoolId])
}

model Household {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardians Guardian[]
  students  Student[]
  school    School @relation("SchoolHousehold", fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([schoolId, name])
}

model StudentHouse {
  id             String @id @default(cuid())
  studentId      String @unique
  houseId        String
  schoolId       String
  academicYearId String

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school       School       @relation("SchoolStudentHouse", fields: [schoolId], references: [id])
  house        House        @relation("StudentHouseHouse", fields: [houseId], references: [id])
  academicYear AcademicYear @relation("StudentHouseAcademicYear", fields: [academicYearId], references: [id])

  @@index([houseId])
  @@index([academicYearId])
  @@index([schoolId])
}

model AdmissionApplication {
  id                     String            @id @default(cuid())
  schoolId               String
  academicYearId         String
  applicationNumber      String            @unique // APP/YYYY/NNNN
  firstName              String
  lastName               String
  otherNames             String?
  dateOfBirth            DateTime
  gender                 Gender
  previousSchool         String?
  jhsIndexNumber         String?
  jhsAggregate           Int?
  programmePreference1Id String?
  programmePreference2Id String?
  guardianName           String
  guardianPhone          String
  guardianEmail          String?
  guardianRelationship   String?
  guardianAddress        String?
  guardianOccupation     String?
  boardingStatus         BoardingStatus    @default(DAY)
  applicationType        ApplicationType   @default(STANDARD)
  applicationSource      ApplicationSource @default(STAFF)
  beceIndexNumber        String?
  enrollmentCode         String?
  placementSchoolCode    String?
  programPlaced          String? // Science, Business, General Arts, etc. (from CSSPS)
  status                 AdmissionStatus   @default(SUBMITTED)
  currentStage           String? // Mirrors WorkflowInstance state for fast filtering
  notes                  String?
  submittedAt            DateTime          @default(now())
  reviewedBy             String?
  reviewedAt             DateTime?

  // Application fee
  applicationFeeRequired  Boolean  @default(true)
  applicationFeePaid      Boolean  @default(false)
  applicationFeeAmount    Decimal? @db.Decimal(18, 2)
  applicationFeePaymentId String?
  feeWaivedReason         String?

  // Interview
  interviewRequired     Boolean @default(false)
  interviewWaivedReason String?

  // Decision
  decisionReason String?
  autoDecision   Boolean @default(false)

  // Offer lifecycle
  offerAccepted            Boolean?
  offerAcceptedAt          DateTime?
  offerExpiryDate          DateTime?
  /// Last time the hourly worker dispatched an "offer expiring soon" warning.
  /// Gates repeat sends; null means never warned.
  offerExpiryWarningSentAt DateTime?

  // Placement verification
  placementVerified   Boolean   @default(false)
  placementVerifiedAt DateTime?
  placementVerifiedBy String?

  // Withdrawal
  withdrawnAt      DateTime?
  withdrawalReason String?

  enrolledStudentId String? // Link to Student record after enrollment
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  documents  AdmissionDocument[]
  interviews AdmissionInterview[]
  decisions  AdmissionDecision[]
  appeals    AdmissionAppeal[]
  offers     AdmissionOffer[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([status])
  @@index([applicationNumber])
  @@index([applicationType])
  @@index([beceIndexNumber])
  @@index([enrollmentCode])
  @@index([guardianPhone])
  @@index([currentStage])
  @@index([offerExpiryDate])
  @@index([placementVerified])
}

model AdmissionDocument {
  id                 String                     @id @default(cuid())
  applicationId      String
  schoolId           String
  documentType       String // e.g., "Birth Certificate", "JHS Report", "Passport Photo", "Placement Letter"
  fileName           String
  fileKey            String // R2 object key — sign at read time via getSignedDownloadUrl
  verificationStatus DocumentVerificationStatus @default(PENDING)
  verifiedBy         String?
  verifiedAt         DateTime?
  rejectionReason    String?
  uploadedAt         DateTime                   @default(now())

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  school      School               @relation("SchoolAdmissionDocument", fields: [schoolId], references: [id])

  @@index([applicationId])
  @@index([schoolId])
  @@index([verificationStatus])
}

// ─── Interview, Decision, Conditions, Appeals, Offers ────────────────

model AdmissionInterview {
  id              String            @id @default(cuid())
  applicationId   String
  schoolId        String
  scheduledAt     DateTime
  location        String?
  panelMemberIds  String[] // User IDs of interviewers
  academicScore   Decimal?          @db.Decimal(5, 2) // 0–10
  behavioralScore Decimal?          @db.Decimal(5, 2) // 0–10
  parentScore     Decimal?          @db.Decimal(5, 2) // 0–10
  totalScore      Decimal?          @db.Decimal(5, 2) // computed 0–10
  outcome         InterviewOutcome?
  notes           String?
  recordedBy      String?
  recordedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  school      School               @relation("SchoolAdmissionInterview", fields: [schoolId], references: [id])

  @@index([applicationId])
  @@index([schoolId])
  @@index([scheduledAt])
  @@index([outcome])
}

model AdmissionDecision {
  id            String                @id @default(cuid())
  applicationId String
  schoolId      String
  decision      AdmissionDecisionType
  decidedBy     String // User ID (or "SYSTEM" for auto-decision)
  decidedAt     DateTime              @default(now())
  reason        String?
  approvedBy    String?
  autoDecision  Boolean               @default(false)

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  school      School               @relation("SchoolAdmissionDecision", fields: [schoolId], references: [id])
  conditions  AdmissionCondition[]

  @@index([applicationId])
  @@index([schoolId])
  @@index([decidedAt])
}

model AdmissionCondition {
  id          String    @id @default(cuid())
  decisionId  String
  type        String // e.g., "PLACEMENT_TEST", "MISSING_DOCS", "MEDICAL_CLEARANCE"
  description String
  deadline    DateTime
  met         Boolean   @default(false)
  metAt       DateTime?
  evidenceKey String? // R2 key
  verifiedBy  String?

  decision AdmissionDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([deadline])
  @@index([met])
}

model AdmissionAppeal {
  id            String       @id @default(cuid())
  applicationId String
  schoolId      String
  submittedBy   String // User ID or guardian identifier
  submittedAt   DateTime     @default(now())
  reason        String
  status        AppealStatus @default(PENDING)
  resolvedBy    String?
  resolvedAt    DateTime?
  resolution    String?

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  school      School               @relation("SchoolAdmissionAppeal", fields: [schoolId], references: [id])

  @@index([applicationId])
  @@index([schoolId])
  @@index([status])
}

model AdmissionOffer {
  id            String    @id @default(cuid())
  applicationId String
  schoolId      String
  issuedAt      DateTime  @default(now())
  expiryDate    DateTime
  acceptedAt    DateTime?
  declinedAt    DateTime?
  declineReason String?

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  school      School               @relation("SchoolAdmissionOffer", fields: [schoolId], references: [id])

  @@index([applicationId])
  @@index([schoolId])
  @@index([expiryDate])
}

// ─── Medical Records ────────────────────────────────────────────────

model MedicalRecord {
  id             String    @id @default(cuid())
  schoolId       String
  studentId      String
  recordedBy     String // User ID (nurse/welfare officer)
  date           DateTime
  type           String // VISIT, CONDITION, ALLERGY, VACCINATION, INJURY, REFERRAL, OTHER
  title          String
  description    String
  treatment      String?
  followUpDate   DateTime?
  isConfidential Boolean   @default(true)
  attachmentKey  String? // R2 file key for any medical documents
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

enum Gender {
  MALE
  FEMALE
}

enum BoardingStatus {
  DAY
  BOARDING
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
  TRANSFERRED
  COMPLETED
  GRADUATED
  DECEASED
}

enum AdmissionStatus {
  DRAFT
  SUBMITTED
  PAYMENT_PENDING
  DOCUMENTS_PENDING
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  AWAITING_DECISION
  ACCEPTED
  CONDITIONAL_ACCEPT
  WAITLISTED
  REJECTED
  OFFER_EXPIRED
  WITHDRAWN
  ENROLLED
  CANCELLED
}

enum InterviewOutcome {
  PASSED
  CONDITIONAL
  FAILED
  NO_SHOW
  WAIVED
}

/// Narrow outcome enum for AdmissionDecision.decision. The full AdmissionStatus
/// enum is kept as the lifecycle state on AdmissionApplication; decisions are
/// one of exactly these four outcomes.
enum AdmissionDecisionType {
  ACCEPTED
  CONDITIONAL_ACCEPT
  WAITLISTED
  REJECTED
}

enum DocumentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppealStatus {
  PENDING
  UPHELD
  DENIED
}

enum ApplicationType {
  STANDARD
  PLACEMENT
}

enum ApplicationSource {
  PORTAL
  STAFF
  BULK_IMPORT
}

// ─── Promotion Runs ────────────────────────────────────────────────

model PromotionRun {
  id                   String             @id @default(cuid())
  schoolId             String
  sourceAcademicYearId String
  targetAcademicYearId String
  sourceClassArmId     String
  status               PromotionRunStatus @default(DRAFT)
  createdBy            String
  committedAt          DateTime?
  committedBy          String?
  revertedAt           DateTime?
  revertedBy           String?
  revertReason         String?
  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  school             School             @relation("SchoolPromotionRun", fields: [schoolId], references: [id], onDelete: Cascade)
  sourceAcademicYear AcademicYear       @relation("SourcePromotionYear", fields: [sourceAcademicYearId], references: [id])
  targetAcademicYear AcademicYear       @relation("TargetPromotionYear", fields: [targetAcademicYearId], references: [id])
  sourceClassArm     ClassArm           @relation("SourcePromotionArm", fields: [sourceClassArmId], references: [id])
  items              PromotionRunItem[]

  @@index([schoolId])
  @@index([status])
  @@index([sourceClassArmId])
  @@index([sourceClassArmId, sourceAcademicYearId])
  @@index([schoolId, status])
  @@index([targetAcademicYearId])
}

model PromotionRunItem {
  id                    String           @id @default(cuid())
  runId                 String
  studentId             String
  outcome               PromotionOutcome
  destinationClassArmId String?
  previousEnrollmentId  String
  previousStatus        StudentStatus
  newEnrollmentId       String?
  notes                 String?
  skippedAt             DateTime?

  run                 PromotionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  student             Student      @relation(fields: [studentId], references: [id])
  destinationClassArm ClassArm?    @relation("DestinationPromotionArm", fields: [destinationClassArmId], references: [id])
  previousEnrollment  Enrollment   @relation("PreviousPromotionEnrollment", fields: [previousEnrollmentId], references: [id])
  newEnrollment       Enrollment?  @relation("NewPromotionEnrollment", fields: [newEnrollmentId], references: [id], onDelete: SetNull)

  @@unique([runId, studentId])
  @@index([runId])
  @@index([studentId])
}

enum PromotionRunStatus {
  DRAFT
  COMMITTED
  REVERTED
}

enum PromotionOutcome {
  PROMOTE
  RETAIN
  GRADUATE
  WITHDRAW
}

model DocumentType {
  id           String            @id @default(cuid())
  schoolId     String
  name         String
  description  String?
  isRequired   Boolean           @default(false)
  expiryMonths Int?
  appliesTo    DocumentAppliesTo @default(ALL)
  status       Status            @default(ACTIVE)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  school    School            @relation("SchoolDocumentType", fields: [schoolId], references: [id], onDelete: Cascade)
  documents StudentDocument[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([schoolId, status])
}

model StudentDocument {
  id                 String                     @id @default(cuid())
  schoolId           String
  studentId          String
  documentTypeId     String
  title              String
  fileKey            String
  fileName           String
  fileSize           Int
  contentType        String
  verificationStatus DocumentVerificationStatus @default(PENDING)
  verifiedBy         String?
  verifiedAt         DateTime?
  rejectionReason    String?
  expiresAt          DateTime?
  notes              String?
  uploadedBy         String
  uploadedAt         DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  school       School       @relation("SchoolStudentDocument", fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([documentTypeId])
  @@index([verificationStatus])
  @@index([expiresAt])
  @@index([schoolId, verificationStatus])
}

enum DocumentAppliesTo {
  ALL
  BOARDING_ONLY
  DAY_ONLY
}

model ReportCardPdfCache {
  id            String    @id @default(cuid())
  schoolId      String
  studentId     String
  termId        String
  fileKey       String
  renderedAt    DateTime  @default(now())
  renderedBy    String
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school  School  @relation("SchoolReportCardCache", fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId])
  @@index([schoolId])
  @@index([termId])
  @@index([invalidatedAt])
}

model PdfJob {
  id             String       @id @default(cuid())
  schoolId       String
  kind           PdfJobKind
  status         PdfJobStatus @default(QUEUED)
  params         Json
  totalItems     Int
  completedItems Int          @default(0)
  resultFileKey  String?
  error          String?
  requestedBy    String
  requestedAt    DateTime     @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  school School @relation("SchoolPdfJob", fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([status])
  @@index([requestedBy])
  @@index([schoolId, status])
}

enum PdfJobKind {
  ID_CARD_BATCH
  REPORT_CARD_BATCH
  TRANSCRIPT_BATCH
}

enum PdfJobStatus {
  QUEUED
  RUNNING
  COMPLETE
  FAILED
  CANCELLED
}
