model Student {
  id              String        @id @default(cuid())
  schoolId        String
  studentId       String        @unique // Auto-generated: SCH/YYYY/NNNN
  userId          String?       @unique // Optional link to User for portal access
  firstName       String
  lastName        String
  otherNames      String?
  dateOfBirth     DateTime
  gender          Gender
  nationality     String?       @default("Ghanaian")
  hometown        String?
  region          String?
  religion        String?
  bloodGroup      String?
  medicalConditions String?
  allergies       String?
  photoUrl        String?
  boardingStatus  BoardingStatus @default(DAY)
  status          StudentStatus @default(ACTIVE)
  enrollmentDate  DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  guardians       StudentGuardian[]
  enrollments     Enrollment[]
  houseAssignment StudentHouse?
  medicalRecords  MedicalRecord[]

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([firstName, lastName])
  @@index([schoolId, status])
  @@index([schoolId, gender, status])
  @@index([schoolId, boardingStatus, status])
}

model Guardian {
  id           String   @id @default(cuid())
  userId       String?  @unique // Optional link to User for parent portal
  firstName    String
  lastName     String
  phone        String
  altPhone     String?
  email        String?
  occupation   String?
  address      String?
  relationship String?  // e.g., Father, Mother, Uncle, Guardian
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students StudentGuardian[]

  @@index([phone])
  @@index([firstName, lastName])
}

model StudentGuardian {
  id         String  @id @default(cuid())
  studentId  String
  guardianId String
  isPrimary  Boolean @default(false)

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([guardianId])
}

model StudentHouse {
  id             String @id @default(cuid())
  studentId      String @unique
  houseId        String
  academicYearId String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([houseId])
  @@index([academicYearId])
}

model AdmissionApplication {
  id                    String          @id @default(cuid())
  schoolId              String
  academicYearId        String
  applicationNumber     String          @unique // APP/YYYY/NNNN
  firstName             String
  lastName              String
  otherNames            String?
  dateOfBirth           DateTime
  gender                Gender
  previousSchool        String?
  jhsIndexNumber        String?
  jhsAggregate          Int?
  programmePreference1Id String?
  programmePreference2Id String?
  guardianName          String
  guardianPhone         String
  guardianEmail         String?
  guardianRelationship  String?
  guardianAddress       String?
  guardianOccupation    String?
  boardingStatus        BoardingStatus  @default(DAY)
  applicationType       ApplicationType @default(STANDARD)
  applicationSource     ApplicationSource @default(STAFF)
  beceIndexNumber       String?
  enrollmentCode        String?
  placementSchoolCode   String?
  status                AdmissionStatus @default(SUBMITTED)
  notes                 String?
  submittedAt           DateTime        @default(now())
  reviewedBy            String?
  reviewedAt            DateTime?
  enrolledStudentId     String?         // Link to Student record after enrollment
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  documents AdmissionDocument[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([status])
  @@index([applicationNumber])
  @@index([applicationType])
  @@index([beceIndexNumber])
  @@index([enrollmentCode])
  @@index([guardianPhone])
}

model AdmissionDocument {
  id            String   @id @default(cuid())
  applicationId String
  documentType  String   // e.g., "Birth Certificate", "JHS Report", "Passport Photo"
  fileName      String
  fileUrl       String
  uploadedAt    DateTime @default(now())

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ─── Medical Records ────────────────────────────────────────────────

model MedicalRecord {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  recordedBy  String   // User ID (nurse/welfare officer)
  date        DateTime
  type        String   // VISIT, CONDITION, ALLERGY, VACCINATION, INJURY, REFERRAL, OTHER
  title       String
  description String
  treatment   String?
  followUpDate DateTime?
  isConfidential Boolean @default(true)
  attachmentKey String? // R2 file key for any medical documents
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

enum Gender {
  MALE
  FEMALE
}

enum BoardingStatus {
  DAY
  BOARDING
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
  TRANSFERRED
  COMPLETED
  GRADUATED
  DECEASED
}

enum AdmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  ACCEPTED
  REJECTED
  ENROLLED
  CANCELLED
}

enum ApplicationType {
  STANDARD
  PLACEMENT
}

enum ApplicationSource {
  PORTAL
  STAFF
  BULK_IMPORT
}
