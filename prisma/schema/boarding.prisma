model Hostel {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  gender      Gender
  capacity    Int      @default(0)
  wardenId    String? // staffId or userId of hostel warden
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dormitories Dormitory[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Dormitory {
  id        String   @id @default(cuid())
  hostelId  String
  schoolId  String
  name      String
  floor     String?
  capacity  Int      @default(0)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostel Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  school School @relation("SchoolDormitory", fields: [schoolId], references: [id])
  beds   Bed[]

  @@unique([hostelId, name])
  @@index([hostelId])
  @@index([schoolId])
}

model Bed {
  id          String    @id @default(cuid())
  dormitoryId String
  schoolId    String
  bedNumber   String
  status      BedStatus @default(AVAILABLE)
  createdAt   DateTime  @default(now())

  dormitory   Dormitory       @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)
  school      School          @relation("SchoolBed", fields: [schoolId], references: [id])
  allocations BedAllocation[]

  @@unique([dormitoryId, bedNumber])
  @@index([dormitoryId])
  @@index([status])
  @@index([schoolId])
}

model BedAllocation {
  id             String              @id @default(cuid())
  bedId          String
  studentId      String
  schoolId       String
  termId         String
  academicYearId String
  allocatedAt    DateTime            @default(now())
  allocatedBy    String // userId
  status         BedAllocationStatus @default(ACTIVE)
  vacatedAt      DateTime?

  bed    Bed    @relation(fields: [bedId], references: [id], onDelete: Cascade)
  school School @relation("SchoolBedAllocation", fields: [schoolId], references: [id])

  @@unique([studentId, termId])
  @@index([bedId])
  @@index([studentId])
  @@index([termId])
  @@index([status])
  @@index([academicYearId])
  @@index([schoolId])
}

model Exeat {
  id                 String      @id @default(cuid())
  exeatNumber        String      @unique // EXT/YYYY/NNNN
  studentId          String
  schoolId           String
  termId             String
  reason             String
  type               ExeatType   @default(NORMAL)
  departureDate      DateTime
  departureTime      String?
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  actualReturnTime   String?
  guardianName       String?
  guardianPhone      String?
  status             ExeatStatus @default(REQUESTED)
  requestedAt        DateTime    @default(now())
  requestedBy        String // userId
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  approvals ExeatApproval[]
  otps      ExeatOtp[]
  movements ExeatMovement[]
  school    School          @relation("SchoolExeat", fields: [schoolId], references: [id])

  @@index([studentId])
  @@index([termId])
  @@index([status])
  @@index([schoolId])
}

model ExeatApproval {
  id           String              @id @default(cuid())
  exeatId      String
  schoolId     String
  approverRole String // e.g., "housemaster", "headmaster"
  approverId   String // userId
  action       ExeatApprovalAction
  comments     String?
  actionAt     DateTime            @default(now())

  exeat  Exeat  @relation(fields: [exeatId], references: [id], onDelete: Cascade)
  school School @relation("SchoolExeatApproval", fields: [schoolId], references: [id])

  @@index([exeatId])
  @@index([schoolId])
}

model RollCall {
  id          String       @id @default(cuid())
  hostelId    String
  schoolId    String
  date        DateTime
  type        RollCallType @default(EVENING)
  conductedBy String // userId
  conductedAt DateTime     @default(now())

  records RollCallRecord[]
  school  School           @relation("SchoolRollCall", fields: [schoolId], references: [id])

  @@unique([hostelId, date, type])
  @@index([hostelId])
  @@index([date])
  @@index([hostelId, date])
  @@index([schoolId])
}

model RollCallRecord {
  id         String         @id @default(cuid())
  rollCallId String
  studentId  String
  schoolId   String
  status     RollCallStatus @default(PRESENT)
  notes      String?

  rollCall RollCall @relation(fields: [rollCallId], references: [id], onDelete: Cascade)
  school   School   @relation("SchoolRollCallRecord", fields: [schoolId], references: [id])

  @@unique([rollCallId, studentId])
  @@index([rollCallId])
  @@index([schoolId])
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum BedAllocationStatus {
  ACTIVE
  VACATED
}

enum ExeatType {
  NORMAL
  EMERGENCY
  MEDICAL
  WEEKEND
  VACATION
}

enum ExeatStatus {
  REQUESTED
  HOUSEMASTER_APPROVED
  HEADMASTER_APPROVED
  REJECTED
  DEPARTED
  RETURNED
  OVERDUE
  CANCELLED
}

enum ExeatApprovalAction {
  APPROVED
  REJECTED
}

enum RollCallType {
  MORNING
  EVENING
}

enum RollCallStatus {
  PRESENT
  ABSENT
  EXEAT
  SICK_BAY
}

// ─── Phase 1: Boarding Incidents ────────────────────────────────────

model BoardingIncident {
  id                 String                   @id @default(cuid())
  schoolId           String
  incidentNumber     String                   @unique // BIN/YYYY/NNNN
  hostelId           String
  dormitoryId        String?
  studentIds         String[]
  reportedBy         String // userId
  date               DateTime
  time               String?
  category           BoardingIncidentCategory
  severity           BoardingIncidentSeverity @default(MINOR)
  title              String
  description        String
  actionTaken        String?
  status             BoardingIncidentStatus   @default(REPORTED)
  resolvedBy         String?
  resolvedAt         DateTime?
  resolution         String?
  linkedDisciplineId String?
  parentNotified     Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([schoolId])
  @@index([hostelId])
  @@index([status])
  @@index([category])
  @@index([severity])
}

enum BoardingIncidentCategory {
  CURFEW_VIOLATION
  PROPERTY_DAMAGE
  BULLYING
  FIGHTING
  UNAUTHORIZED_ABSENCE
  SUBSTANCE_ABUSE
  THEFT
  NOISE_DISTURBANCE
  HEALTH_EMERGENCY
  SAFETY_HAZARD
  OTHER
}

enum BoardingIncidentSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum BoardingIncidentStatus {
  REPORTED
  INVESTIGATING
  ACTION_TAKEN
  RESOLVED
  ESCALATED
  DISMISSED
}

// ─── Phase 2: Sick Bay & Health Tracking ────────────────────────────

model SickBayAdmission {
  id               String          @id @default(cuid())
  schoolId         String
  admissionNumber  String          @unique // SBA/YYYY/NNNN
  studentId        String
  hostelId         String
  admittedBy       String // userId
  admittedAt       DateTime        @default(now())
  symptoms         String
  initialDiagnosis String?
  temperature      Decimal?
  severity         SickBaySeverity @default(MILD)
  status           SickBayStatus   @default(ADMITTED)
  treatmentNotes   String?
  dischargedBy     String?
  dischargedAt     DateTime?
  dischargeNotes   String?
  referredTo       String?
  parentNotified   Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  medications MedicationLog[]

  @@index([schoolId])
  @@index([studentId])
  @@index([hostelId])
  @@index([status])
}

model MedicationLog {
  id                 String   @id @default(cuid())
  sickBayAdmissionId String
  schoolId           String
  medicationName     String
  dosage             String
  administeredBy     String // userId
  administeredAt     DateTime @default(now())
  notes              String?

  admission SickBayAdmission @relation(fields: [sickBayAdmissionId], references: [id], onDelete: Cascade)
  school    School           @relation("SchoolMedicationLog", fields: [schoolId], references: [id])

  @@index([sickBayAdmissionId])
  @@index([schoolId])
}

enum SickBaySeverity {
  MILD
  MODERATE
  SEVERE
  EMERGENCY
}

enum SickBayStatus {
  ADMITTED
  UNDER_OBSERVATION
  DISCHARGED
  REFERRED
}

// ─── Phase 3: Visitor Management ────────────────────────────────────

model BoardingVisitor {
  id              String        @id @default(cuid())
  schoolId        String
  studentId       String
  visitorName     String
  relationship    String
  visitorPhone    String
  visitorIdNumber String?
  purpose         String
  checkInAt       DateTime      @default(now())
  checkOutAt      DateTime?
  checkedInBy     String // userId
  checkedOutBy    String?
  status          VisitorStatus @default(CHECKED_IN)
  hostelId        String
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@index([hostelId])
  @@index([status])
  @@index([checkInAt])
}

enum VisitorStatus {
  CHECKED_IN
  CHECKED_OUT
}

// ─── Phase 4: Bed Transfer Management ───────────────────────────────

model BedTransfer {
  id              String            @id @default(cuid())
  schoolId        String
  transferNumber  String            @unique // BTR/YYYY/NNNN
  studentId       String
  fromBedId       String
  toBedId         String
  reason          BedTransferReason
  reasonDetails   String?
  requestedBy     String // userId
  requestedAt     DateTime          @default(now())
  status          BedTransferStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  effectiveDate   DateTime?
  completedAt     DateTime?
  rejectionReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

enum BedTransferReason {
  STUDENT_REQUEST
  DISCIPLINARY
  MEDICAL
  MAINTENANCE
  CONFLICT_RESOLUTION
  REBALANCING
  OTHER
}

enum BedTransferStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
}

// ─── Phase 5: Hostel Inspection & Maintenance ───────────────────────

model HostelInspection {
  id                String           @id @default(cuid())
  schoolId          String
  hostelId          String
  dormitoryId       String?
  inspectedBy       String // userId
  inspectionDate    DateTime
  type              InspectionType   @default(ROUTINE)
  overallRating     InspectionRating
  cleanlinessRating InspectionRating
  facilityRating    InspectionRating
  safetyRating      InspectionRating
  remarks           String?
  issues            String?
  followUpRequired  Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([schoolId])
  @@index([hostelId])
  @@index([inspectionDate])
}

model MaintenanceRequest {
  id              String              @id @default(cuid())
  schoolId        String
  requestNumber   String              @unique // MNT/YYYY/NNNN
  hostelId        String
  dormitoryId     String?
  bedId           String?
  reportedBy      String // userId
  title           String
  description     String
  category        MaintenanceCategory
  priority        MaintenancePriority @default(MEDIUM)
  status          MaintenanceStatus   @default(OPEN)
  assignedTo      String?
  assignedAt      DateTime?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([schoolId])
  @@index([hostelId])
  @@index([status])
  @@index([priority])
}

enum InspectionType {
  ROUTINE
  SURPRISE
  FOLLOW_UP
  END_OF_TERM
}

enum InspectionRating {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  FURNITURE
  STRUCTURAL
  CLEANING
  PEST_CONTROL
  SECURITY
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Phase 2: Guardian OTP for exeat release ────────────────────────
// The guardian must verify a one-time code (sent via SMS/WhatsApp) before
// the gate officer is allowed to release the student. Ties into the exeat
// workflow as a required transition.

model ExeatOtp {
  id          String          @id @default(cuid())
  exeatId     String
  schoolId    String
  // Hashed 6-digit code (never store the plaintext).
  codeHash    String
  channel     ExeatOtpChannel
  sentTo      String // phone number or WhatsApp ID that received it
  sentAt      DateTime        @default(now())
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int             @default(0)
  maxAttempts Int             @default(5)
  status      ExeatOtpStatus  @default(SENT)

  exeat Exeat @relation(fields: [exeatId], references: [id], onDelete: Cascade)

  @@index([exeatId])
  @@index([schoolId])
  @@index([status, expiresAt])
}

enum ExeatOtpChannel {
  SMS
  WHATSAPP
}

enum ExeatOtpStatus {
  SENT
  VERIFIED
  EXPIRED
  FAILED // attempts exceeded
}

// ─── Phase 2: Gate depart/return movements ──────────────────────────
// Dedicated log of physical departures and returns so we can trend gate
// activity, detect overdue returns, and attach geolocation / officer
// identity to each event. Exeat.status stays authoritative for workflow,
// but these rows are the audit trail for "did the student actually leave".

model ExeatMovement {
  id         String            @id @default(cuid())
  exeatId    String
  schoolId   String
  kind       ExeatMovementKind
  officerId  String // userId of gate officer
  occurredAt DateTime          @default(now())
  geoLat     Decimal?          @db.Decimal(10, 7)
  geoLng     Decimal?          @db.Decimal(10, 7)
  notes      String?

  exeat Exeat @relation(fields: [exeatId], references: [id], onDelete: Cascade)

  @@index([exeatId])
  @@index([schoolId])
  @@index([occurredAt])
  @@index([kind])
}

enum ExeatMovementKind {
  DEPART
  RETURN
}
