// ─── Phase 2: Bank Reconciliation ─────────────────────────────────

model BankReconciliation {
  id               String               @id @default(cuid())
  schoolId         String
  bankName         String
  accountNumber    String?
  statementDate    DateTime
  fileName         String?
  uploadedBy       String // userId
  uploadedAt       DateTime             @default(now())
  status           ReconciliationStatus @default(PENDING)
  totalEntries     Int                  @default(0)
  matchedEntries   Int                  @default(0)
  unmatchedEntries Int                  @default(0)

  entries BankStatementEntry[]

  @@index([schoolId])
  @@index([status])
}

model BankStatementEntry {
  id                   String      @id @default(cuid())
  bankReconciliationId String
  schoolId             String
  transactionDate      DateTime
  description          String
  reference            String?
  debitAmount          Decimal?    @db.Decimal(18, 2)
  creditAmount         Decimal?    @db.Decimal(18, 2)
  balance              Decimal?    @db.Decimal(18, 2)
  matchedPaymentId     String? // matched Payment record
  matchStatus          MatchStatus @default(UNMATCHED)
  matchedAt            DateTime?
  matchedBy            String? // userId

  bankReconciliation BankReconciliation @relation(fields: [bankReconciliationId], references: [id], onDelete: Cascade)
  school             School             @relation("SchoolBankStatementEntry", fields: [schoolId], references: [id])

  @@index([bankReconciliationId])
  @@index([matchStatus])
