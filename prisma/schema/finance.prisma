model FeeStructure {
  id             String             @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  programmeId    String?            // null = all programmes
  boardingStatus BoardingStatus?    // null = both day and boarding
  name           String
  status         FeeStructureStatus @default(DRAFT)
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  feeItems FeeItem[]
  bills    StudentBill[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([status])
}

model FeeItem {
  id             String  @id @default(cuid())
  feeStructureId String
  name           String  // e.g., Tuition, Boarding, Feeding, PTA, Exam Fee
  code           String?
  amount         Decimal  @db.Decimal(18, 2)
  isOptional     Boolean @default(false)
  description    String?

  feeStructure  FeeStructure    @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  billItems     StudentBillItem[]

  @@index([feeStructureId])
}

model StudentBill {
  id             String     @id @default(cuid())
  studentId      String
  feeStructureId String
  termId         String
  academicYearId String
  totalAmount    Decimal    @db.Decimal(18, 2)
  paidAmount     Decimal    @default(0) @db.Decimal(18, 2)
  balanceAmount  Decimal    @db.Decimal(18, 2)
  status         BillStatus @default(UNPAID)
  generatedAt    DateTime   @default(now())
  dueDate        DateTime?
  updatedAt      DateTime   @updatedAt

  feeStructure FeeStructure    @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  billItems    StudentBillItem[]
  payments     Payment[]
  installments StudentInstallment[]
  penalties    AppliedPenalty[]
  waivers      FeeWaiver[]

  @@unique([studentId, feeStructureId])
  @@index([studentId])
  @@index([termId])
  @@index([academicYearId])
  @@index([status])
  @@index([feeStructureId])
  @@index([studentId, status])
  @@index([termId, status])
}

model StudentBillItem {
  id            String @id @default(cuid())
  studentBillId String
  feeItemId     String
  amount        Decimal @db.Decimal(18, 2)
  waivedAmount  Decimal @default(0) @db.Decimal(18, 2)
  paidAmount    Decimal @default(0) @db.Decimal(18, 2)

  studentBill StudentBill @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  feeItem     FeeItem     @relation(fields: [feeItemId], references: [id], onDelete: Cascade)

  @@unique([studentBillId, feeItemId])
  @@index([studentBillId])
}

model Payment {
  id             String        @id @default(cuid())
  studentBillId  String
  studentId      String
  amount         Decimal       @db.Decimal(18, 2)
  paymentMethod  PaymentMethod
  referenceNumber String?
  receivedBy     String        // userId
  receivedAt     DateTime      @default(now())
  status         PaymentStatus @default(CONFIRMED)
  notes          String?
  createdAt      DateTime      @default(now())

  studentBill StudentBill @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  receipt     Receipt?
  reversal    PaymentReversal?

  @@index([studentBillId])
  @@index([studentId])
  @@index([receivedAt])
  @@index([status])
  @@index([studentId, receivedAt])
}

model Receipt {
  id            String   @id @default(cuid())
  paymentId     String   @unique
  receiptNumber String   @unique // RCP/YYYY/T{n}/NNNN
  generatedAt   DateTime @default(now())
  fileUrl       String?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([receiptNumber])
}

model Scholarship {
  id             String          @id @default(cuid())
  schoolId       String
  name           String
  type           ScholarshipType
  value          Decimal         @db.Decimal(18, 2) // percentage or fixed amount
  criteria       String?
  academicYearId String?
  status         Status          @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  studentScholarships StudentScholarship[]

  @@index([schoolId])
}

model StudentScholarship {
  id            String @id @default(cuid())
  studentId     String
  scholarshipId String
  appliedAmount Decimal @db.Decimal(18, 2)
  termId        String
  createdAt     DateTime @default(now())

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([studentId, scholarshipId, termId])
  @@index([studentId])
  @@index([scholarshipId])
  @@index([termId])
}

model PaymentReversal {
  id         String   @id @default(cuid())
  paymentId  String   @unique
  reason     String
  reversedBy String   // userId who initiated
  reversedAt DateTime @default(now())
  approvedBy String?  // userId who approved
  approvedAt DateTime?
  status     ReversalStatus @default(PENDING)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
}

enum FeeStructureStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
  OVERPAID
  WAIVED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CHEQUE
  OTHER
}

enum PaymentStatus {
  CONFIRMED
  REVERSED
}

enum ScholarshipType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReversalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 1A: Fee Templates ──────────────────────────────────────

model FeeTemplate {
  id             String          @id @default(cuid())
  schoolId       String
  name           String
  description    String?
  boardingStatus BoardingStatus?
  programmeId    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items FeeTemplateItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FeeTemplateItem {
  id            String  @id @default(cuid())
  feeTemplateId String
  name          String
  code          String?
  amount        Decimal @db.Decimal(18, 2)
  isOptional    Boolean @default(false)
  description   String?

  feeTemplate FeeTemplate @relation(fields: [feeTemplateId], references: [id], onDelete: Cascade)

  @@index([feeTemplateId])
}

// ─── Phase 1A: Installment Plans ──────────────────────────────────

model InstallmentPlan {
  id                   String   @id @default(cuid())
  schoolId             String
  feeStructureId       String?  // null = school-wide default plan
  name                 String
  numberOfInstallments Int
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  schedules           InstallmentSchedule[]
  studentInstallments StudentInstallment[]

  @@index([schoolId])
  @@index([feeStructureId])
}

model InstallmentSchedule {
  id                String @id @default(cuid())
  installmentPlanId String
  installmentNumber Int
  percentageOfTotal Decimal @db.Decimal(5, 2) // e.g., 40.0 for 40%
  dueDaysFromStart  Int    // days from term start date
  label             String? // "1st Installment", "2nd Installment"

  installmentPlan InstallmentPlan @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)

  @@unique([installmentPlanId, installmentNumber])
  @@index([installmentPlanId])
}

model StudentInstallment {
  id                String            @id @default(cuid())
  studentBillId     String
  installmentPlanId String
  installmentNumber Int
  amount            Decimal           @db.Decimal(18, 2)
  dueDate           DateTime
  paidAmount        Decimal           @default(0) @db.Decimal(18, 2)
  status            InstallmentStatus @default(PENDING)
  paidAt            DateTime?

  studentBill     StudentBill     @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  installmentPlan InstallmentPlan @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)

  @@unique([studentBillId, installmentPlanId, installmentNumber])
  @@index([studentBillId])
  @@index([dueDate])
  @@index([status])
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

// ─── Phase 1A: Late Penalty Rules ─────────────────────────────────

model LatePenaltyRule {
  id              String      @id @default(cuid())
  schoolId        String
  feeStructureId  String?     // null = applies to all active fee structures
  name            String
  type            PenaltyType
  value           Decimal     @db.Decimal(18, 4) // percentage or fixed amount
  gracePeriodDays Int         @default(0)
  maxPenalty      Decimal?    @db.Decimal(18, 2) // cap on total penalty
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  penalties AppliedPenalty[]

  @@index([schoolId])
  @@index([feeStructureId])
}

model AppliedPenalty {
  id                String   @id @default(cuid())
  studentBillId     String
  latePenaltyRuleId String
  amount            Decimal  @db.Decimal(18, 2)
  appliedAt         DateTime @default(now())
  waived            Boolean  @default(false)
  waivedBy          String?  // userId
  waivedAt          DateTime?

  studentBill     StudentBill     @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  latePenaltyRule LatePenaltyRule @relation(fields: [latePenaltyRuleId], references: [id], onDelete: Cascade)

  @@index([studentBillId])
  @@index([latePenaltyRuleId])
}

enum PenaltyType {
  PERCENTAGE       // one-time percentage of outstanding balance
  FIXED_AMOUNT     // one-time fixed surcharge
  DAILY_PERCENTAGE // daily accruing percentage
  DAILY_FIXED      // daily accruing fixed amount
}

// ─── Phase 1A: Fee Waivers ────────────────────────────────────────

model FeeWaiver {
  id                String       @id @default(cuid())
  schoolId          String
  studentBillId     String
  studentBillItemId String?      // null = entire bill, specific = per line item
  requestedBy       String       // userId
  approvedBy        String?
  reason            String
  waiverType        WaiverType
  value             Decimal      @db.Decimal(18, 2) // percentage or fixed amount
  calculatedAmount  Decimal      @db.Decimal(18, 2) // actual GHS amount waived
  status            WaiverStatus @default(PENDING)
  requestedAt       DateTime     @default(now())
  reviewedAt        DateTime?
  notes             String?

  studentBill StudentBill @relation(fields: [studentBillId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentBillId])
  @@index([status])
}

enum WaiverType {
  PERCENTAGE
  FIXED_AMOUNT
  FULL_WAIVER
  STAFF_CHILD_DISCOUNT
  SIBLING_DISCOUNT
}

enum WaiverStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 1B: Government Subsidies (Free SHS) ───────────────────

model GovernmentSubsidy {
  id              String        @id @default(cuid())
  schoolId        String
  name            String        // "Free SHS Subsidy Term 1", "Capitation Grant 2026"
  subsidyType     SubsidyType
  academicYearId  String
  termId          String?
  expectedAmount  Decimal       @db.Decimal(18, 2)
  receivedAmount  Decimal       @default(0) @db.Decimal(18, 2)
  status          SubsidyStatus @default(EXPECTED)
  referenceNumber String?       // Government reference / voucher number
  receivedAt      DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  disbursements SubsidyDisbursement[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([status])
}

model SubsidyDisbursement {
  id                  String   @id @default(cuid())
  governmentSubsidyId String
  amount              Decimal  @db.Decimal(18, 2)
  receivedAt          DateTime
  bankReference       String?
  recordedBy          String   // userId
  notes               String?
  createdAt           DateTime @default(now())

  governmentSubsidy GovernmentSubsidy @relation(fields: [governmentSubsidyId], references: [id], onDelete: Cascade)

  @@index([governmentSubsidyId])
}

enum SubsidyType {
  FREE_SHS
  GOVERNMENT_PLACEMENT
  CAPITATION_GRANT
  OTHER_GOVERNMENT
}

enum SubsidyStatus {
  EXPECTED
  PARTIALLY_RECEIVED
  RECEIVED
  OVERDUE
}

// ─── Phase 1B: Donor Funds ───────────────────────────────────────

model DonorFund {
  id              String   @id @default(cuid())
  schoolId        String
  donorName       String
  donorType       DonorType
  contactEmail    String?
  contactPhone    String?
  totalPledged    Decimal  @db.Decimal(18, 2)
  totalReceived   Decimal  @default(0) @db.Decimal(18, 2)
  totalDisbursed  Decimal  @default(0) @db.Decimal(18, 2)
  purpose         String?  // Restriction on fund usage
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  allocations DonorFundAllocation[]

  @@index([schoolId])
  @@index([isActive])
}

model DonorFundAllocation {
  id           String   @id @default(cuid())
  donorFundId  String
  studentId    String
  termId       String
  amount       Decimal @db.Decimal(18, 2)
  description  String?
  allocatedBy  String   // userId
  allocatedAt  DateTime @default(now())

  donorFund DonorFund @relation(fields: [donorFundId], references: [id], onDelete: Cascade)

  @@index([donorFundId])
  @@index([studentId])
  @@index([termId])
}

enum DonorType {
  INDIVIDUAL
  ORGANIZATION
  FOUNDATION
  ALUMNI
  CORPORATE
}

// ─── Phase 1B: Financial Aid Applications ────────────────────────

model FinancialAidApplication {
  id                String         @id @default(cuid())
  schoolId          String
  studentId         String
  academicYearId    String
  termId            String
  aidType           AidType
  requestedAmount   Decimal        @db.Decimal(18, 2)
  approvedAmount    Decimal?       @db.Decimal(18, 2)
  reason            String
  supportingDocs    String[]       // URLs to uploaded documents
  householdIncome   Decimal?       @db.Decimal(18, 2)
  numberOfDependents Int?
  status            AidStatus      @default(SUBMITTED)
  submittedBy       String         // userId (parent or admin)
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([status])
}

enum AidType {
  NEEDS_BASED
  MERIT_BASED
  HARDSHIP
  ORPHAN_SUPPORT
  COMMUNITY_SPONSORED
}

enum AidStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
}

// ─── Phase 2: Online Payment Transactions ─────────────────────────

model OnlinePaymentTransaction {
  id              String                @id @default(cuid())
  schoolId        String
  studentBillId   String
  studentId       String
  provider        String                // paystack, flutterwave, mtn_momo, telecel_cash, etc.
  reference       String                @unique
  amount          Decimal               @db.Decimal(18, 2)
  currency        String                @default("GHS")
  status          OnlinePaymentStatus   @default(INITIATED)
  providerReference String?
  channel         String?               // mobile_money, card, bank_transfer
  callbackUrl     String?
  metadata        Json?
  initiatedAt     DateTime              @default(now())
  completedAt     DateTime?
  failureReason   String?

  @@index([schoolId])
  @@index([studentBillId])
  @@index([reference])
  @@index([status])
  @@index([provider])
}

enum OnlinePaymentStatus {
  INITIATED
  PENDING
  SUCCESSFUL
  FAILED
  CANCELLED
  EXPIRED
}

// ─── Phase 2: Payment Links ──────────────────────────────────────

model PaymentLink {
  id              String          @id @default(cuid())
  schoolId        String
  studentBillId   String
  code            String          @unique // short URL-safe code
  amount          Decimal?        @db.Decimal(18, 2) // null = pay any amount up to balance
  description     String?
  expiresAt       DateTime?
  isOneTime       Boolean         @default(true)
  isActive        Boolean         @default(true)
  usedCount       Int             @default(0)
  createdBy       String          // userId
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([schoolId])
  @@index([code])
  @@index([studentBillId])
  @@index([isActive])
}

// ─── Phase 2: Bank Reconciliation ─────────────────────────────────

model BankReconciliation {
  id              String                  @id @default(cuid())
  schoolId        String
  bankName        String
  accountNumber   String?
  statementDate   DateTime
  fileName        String?
  uploadedBy      String                  // userId
  uploadedAt      DateTime                @default(now())
  status          ReconciliationStatus    @default(PENDING)
  totalEntries    Int                     @default(0)
  matchedEntries  Int                     @default(0)
  unmatchedEntries Int                    @default(0)

  entries BankStatementEntry[]

  @@index([schoolId])
  @@index([status])
}

model BankStatementEntry {
  id                  String              @id @default(cuid())
  bankReconciliationId String
  transactionDate     DateTime
  description         String
  reference           String?
  debitAmount         Decimal?        @db.Decimal(18, 2)
  creditAmount        Decimal?        @db.Decimal(18, 2)
  balance             Decimal?        @db.Decimal(18, 2)
  matchedPaymentId    String?             // matched Payment record
  matchStatus         MatchStatus         @default(UNMATCHED)
  matchedAt           DateTime?
  matchedBy           String?             // userId

  bankReconciliation BankReconciliation @relation(fields: [bankReconciliationId], references: [id], onDelete: Cascade)

  @@index([bankReconciliationId])
  @@index([matchStatus])
  @@index([reference])
}

enum ReconciliationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum MatchStatus {
  UNMATCHED
  AUTO_MATCHED
  MANUALLY_MATCHED
  NO_MATCH
}
