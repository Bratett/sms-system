  school            School            @relation("SchoolSubsidyDisbursement", fields: [schoolId], references: [id])

  @@index([governmentSubsidyId])
  @@index([schoolId])
}

enum SubsidyType {
  FREE_SHS
  GOVERNMENT_PLACEMENT
  CAPITATION_GRANT
  OTHER_GOVERNMENT
}

enum SubsidyStatus {
  EXPECTED
  PARTIALLY_RECEIVED
  RECEIVED
  OVERDUE
}

