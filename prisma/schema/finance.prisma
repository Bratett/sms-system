model FeeStructure {
  id             String             @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  programmeId    String? // null = all programmes
  boardingStatus BoardingStatus? // null = both day and boarding
  name           String
  status         FeeStructureStatus @default(DRAFT)
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  feeItems FeeItem[]
  bills    StudentBill[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([status])
}

model FeeItem {
  id             String      @id @default(cuid())
  feeStructureId String
  schoolId       String
  name           String // e.g., Tuition, Boarding, Feeding, PTA, Exam Fee
  code           String?
  amount         Decimal     @db.Decimal(18, 2)
  isOptional     Boolean     @default(false)
  /// Category taxonomy used by billing to decide Free-SHS waivers.
  /// Existing rows default to OTHER — admins reclassify TUITION items via the Fee Structure UI.
  type           FeeItemType @default(OTHER)
  description    String?

  feeStructure FeeStructure      @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  school       School            @relation("SchoolFeeItem", fields: [schoolId], references: [id])
  billItems    StudentBillItem[]

  @@index([feeStructureId])
  @@index([schoolId])
  @@index([type])
}

enum FeeItemType {
  TUITION
  BOARDING
  FEEDING
  PTA
  BOOKS
  OTHER
}

model StudentBill {
  id                String     @id @default(cuid())
  studentId         String
  feeStructureId    String
  schoolId          String
  termId            String
  academicYearId    String
  totalAmount       Decimal    @db.Decimal(18, 2)
  paidAmount        Decimal    @default(0) @db.Decimal(18, 2)
  balanceAmount     Decimal    @db.Decimal(18, 2)
  writtenOffAmount  Decimal    @default(0) @db.Decimal(18, 2)
  status            BillStatus @default(UNPAID)
  generatedAt       DateTime   @default(now())
  dueDate           DateTime?
  accrualJournalId  String? // Dr AR / Cr Fee Revenue at bill generation
  writeOffJournalId String? // if written off as uncollectible
  updatedAt         DateTime   @updatedAt

  feeStructure FeeStructure         @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  school       School               @relation("SchoolStudentBill", fields: [schoolId], references: [id])
  billItems    StudentBillItem[]
  payments     Payment[]
  installments StudentInstallment[]
  penalties    AppliedPenalty[]
  waivers      FeeWaiver[]

  @@unique([studentId, feeStructureId])
  @@index([studentId])
  @@index([termId])
  @@index([academicYearId])
  @@index([status])
  @@index([feeStructureId])
  @@index([studentId, status])
  @@index([termId, status])
  @@index([schoolId])
}

model StudentBillItem {
  id            String  @id @default(cuid())
  studentBillId String
  feeItemId     String
  schoolId      String
  amount        Decimal @db.Decimal(18, 2)
  waivedAmount  Decimal @default(0) @db.Decimal(18, 2)
  paidAmount    Decimal @default(0) @db.Decimal(18, 2)

  studentBill StudentBill @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  feeItem     FeeItem     @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  school      School      @relation("SchoolStudentBillItem", fields: [schoolId], references: [id])

  @@unique([studentBillId, feeItemId])
  @@index([studentBillId])
  @@index([schoolId])
}

model Payment {
  id                   String        @id @default(cuid())
  studentBillId        String
  studentId            String
  schoolId             String
  amount               Decimal       @db.Decimal(18, 2)
  paymentMethod        PaymentMethod
  referenceNumber      String?
  receivedBy           String // userId
  receivedAt           DateTime      @default(now())
  status               PaymentStatus @default(CONFIRMED)
  notes                String?
  journalTransactionId String? // Dr Cash/Bank / Cr AR
  createdAt            DateTime      @default(now())

  studentBill StudentBill      @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  school      School           @relation("SchoolPayment", fields: [schoolId], references: [id])
  receipt     Receipt?
  reversal    PaymentReversal?

  @@index([studentBillId])
  @@index([studentId])
  @@index([receivedAt])
  @@index([status])
  @@index([studentId, receivedAt])
  @@index([schoolId])
}

model Receipt {
  id            String   @id @default(cuid())
  paymentId     String   @unique
  schoolId      String
  receiptNumber String   @unique // RCP/YYYY/T{n}/NNNN
  generatedAt   DateTime @default(now())
  fileUrl       String?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  school  School  @relation("SchoolReceipt", fields: [schoolId], references: [id])

  @@index([receiptNumber])
  @@index([schoolId])
}

model Scholarship {
  id             String          @id @default(cuid())
  schoolId       String
  name           String
  type           ScholarshipType
  value          Decimal         @db.Decimal(18, 2) // percentage or fixed amount
  criteria       String?
  academicYearId String?
  status         Status          @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  studentScholarships StudentScholarship[]

  @@index([schoolId])
}

model StudentScholarship {
  id                   String   @id @default(cuid())
  studentId            String
  scholarshipId        String
  schoolId             String
  appliedAmount        Decimal  @db.Decimal(18, 2)
  termId               String
  journalTransactionId String?
  createdAt            DateTime @default(now())

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  school      School      @relation("SchoolStudentScholarship", fields: [schoolId], references: [id])

  @@unique([studentId, scholarshipId, termId])
  @@index([studentId])
  @@index([scholarshipId])
  @@index([termId])
  @@index([schoolId])
}

model PaymentReversal {
  id                   String         @id @default(cuid())
  paymentId            String         @unique
  schoolId             String
  reason               String
  reversedBy           String // userId who initiated
  reversedAt           DateTime       @default(now())
  approvedBy           String? // userId who approved
  approvedAt           DateTime?
  status               ReversalStatus @default(PENDING)
  journalTransactionId String? // reversal journal when approved

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  school  School  @relation("SchoolPaymentReversal", fields: [schoolId], references: [id])

  @@index([paymentId])
  @@index([status])
  @@index([schoolId])
}

enum FeeStructureStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
  OVERPAID
  WAIVED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CHEQUE
  OTHER
}

enum PaymentStatus {
  CONFIRMED
  REVERSED
}

enum ScholarshipType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReversalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 1A: Fee Templates ──────────────────────────────────────

model FeeTemplate {
  id             String          @id @default(cuid())
  schoolId       String
  name           String
  description    String?
  boardingStatus BoardingStatus?
  programmeId    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items FeeTemplateItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FeeTemplateItem {
  id            String  @id @default(cuid())
  feeTemplateId String
  schoolId      String
  name          String
  code          String?
  amount        Decimal @db.Decimal(18, 2)
  isOptional    Boolean @default(false)
  description   String?

  feeTemplate FeeTemplate @relation(fields: [feeTemplateId], references: [id], onDelete: Cascade)
  school      School      @relation("SchoolFeeTemplateItem", fields: [schoolId], references: [id])

  @@index([feeTemplateId])
  @@index([schoolId])
}

// ─── Phase 1A: Installment Plans ──────────────────────────────────

model InstallmentPlan {
  id                   String   @id @default(cuid())
  schoolId             String
  feeStructureId       String? // null = school-wide default plan
  name                 String
  numberOfInstallments Int
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  schedules           InstallmentSchedule[]
  studentInstallments StudentInstallment[]

  @@index([schoolId])
  @@index([feeStructureId])
}

model InstallmentSchedule {
  id                String  @id @default(cuid())
  installmentPlanId String
  schoolId          String
  installmentNumber Int
  percentageOfTotal Decimal @db.Decimal(5, 2) // e.g., 40.0 for 40%
  dueDaysFromStart  Int // days from term start date
  label             String? // "1st Installment", "2nd Installment"

  installmentPlan InstallmentPlan @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)
  school          School          @relation("SchoolInstallmentSchedule", fields: [schoolId], references: [id])

  @@unique([installmentPlanId, installmentNumber])
  @@index([installmentPlanId])
  @@index([schoolId])
}

model StudentInstallment {
  id                String            @id @default(cuid())
  studentBillId     String
  installmentPlanId String
  schoolId          String
  installmentNumber Int
  amount            Decimal           @db.Decimal(18, 2)
  dueDate           DateTime
  paidAmount        Decimal           @default(0) @db.Decimal(18, 2)
  status            InstallmentStatus @default(PENDING)
  paidAt            DateTime?

  studentBill     StudentBill     @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  installmentPlan InstallmentPlan @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)
  school          School          @relation("SchoolStudentInstallment", fields: [schoolId], references: [id])

  @@unique([studentBillId, installmentPlanId, installmentNumber])
  @@index([studentBillId])
  @@index([dueDate])
  @@index([status])
  @@index([schoolId])
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

// ─── Phase 1A: Late Penalty Rules ─────────────────────────────────

model LatePenaltyRule {
  id              String      @id @default(cuid())
  schoolId        String
  feeStructureId  String? // null = applies to all active fee structures
  name            String
  type            PenaltyType
  value           Decimal     @db.Decimal(18, 4) // percentage or fixed amount
  gracePeriodDays Int         @default(0)
  maxPenalty      Decimal?    @db.Decimal(18, 2) // cap on total penalty
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  penalties AppliedPenalty[]

  @@index([schoolId])
  @@index([feeStructureId])
}

model AppliedPenalty {
  id                   String    @id @default(cuid())
  studentBillId        String
  latePenaltyRuleId    String
  schoolId             String
  amount               Decimal   @db.Decimal(18, 2)
  appliedAt            DateTime  @default(now())
  waived               Boolean   @default(false)
  waivedBy             String? // userId
  waivedAt             DateTime?
  journalTransactionId String? // Dr AR / Cr Penalty Revenue
  waiverJournalId      String? // reversal when waived

  studentBill     StudentBill     @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  latePenaltyRule LatePenaltyRule @relation(fields: [latePenaltyRuleId], references: [id], onDelete: Cascade)
  school          School          @relation("SchoolAppliedPenalty", fields: [schoolId], references: [id])

  @@index([studentBillId])
  @@index([latePenaltyRuleId])
  @@index([schoolId])
}

enum PenaltyType {
  PERCENTAGE // one-time percentage of outstanding balance
  FIXED_AMOUNT // one-time fixed surcharge
  DAILY_PERCENTAGE // daily accruing percentage
  DAILY_FIXED // daily accruing fixed amount
}

// ─── Phase 1A: Fee Waivers ────────────────────────────────────────

model FeeWaiver {
  id                String       @id @default(cuid())
  schoolId          String
  studentBillId     String
  studentBillItemId String? // null = entire bill, specific = per line item
  requestedBy       String // userId
  approvedBy        String?
  reason            String
  waiverType        WaiverType
  value             Decimal      @db.Decimal(18, 2) // percentage or fixed amount
  calculatedAmount  Decimal      @db.Decimal(18, 2) // actual GHS amount waived
  status            WaiverStatus @default(PENDING)
  requestedAt       DateTime     @default(now())
  reviewedAt        DateTime?
  notes             String?

  journalTransactionId String?

  studentBill StudentBill @relation(fields: [studentBillId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentBillId])
  @@index([status])
}

enum WaiverType {
  PERCENTAGE
  FIXED_AMOUNT
  FULL_WAIVER
  STAFF_CHILD_DISCOUNT
  SIBLING_DISCOUNT
}

enum WaiverStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 1B: Government Subsidies (Free SHS) ───────────────────

model GovernmentSubsidy {
  id              String        @id @default(cuid())
  schoolId        String
  name            String // "Free SHS Subsidy Term 1", "Capitation Grant 2026"
  subsidyType     SubsidyType
  academicYearId  String
  termId          String?
  expectedAmount  Decimal       @db.Decimal(18, 2)
  receivedAmount  Decimal       @default(0) @db.Decimal(18, 2)
  status          SubsidyStatus @default(EXPECTED)
  referenceNumber String? // Government reference / voucher number
  receivedAt      DateTime?
  notes           String?
  isConditional   Boolean       @default(false) // IPSAS 23 — conditional grants go to Deferred Inflow until conditions met
  fundId          String? // restricted fund for this subsidy
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  disbursements SubsidyDisbursement[]

  @@index([schoolId])
  @@index([academicYearId])
