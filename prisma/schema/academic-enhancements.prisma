// ─── Phase 2: Student Elective Selection ────────────────────────────

model StudentSubjectSelection {
  id               String          @id @default(cuid())
  studentId        String
  subjectId        String
  academicYearId   String
  schoolId         String
  status           SelectionStatus @default(PENDING)
  selectedAt       DateTime        @default(now())
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school  School  @relation("SchoolStudentSubjectSelections", fields: [schoolId], references: [id])

  @@unique([studentId, subjectId, academicYearId])
  @@index([studentId])
  @@index([subjectId])
  @@index([academicYearId])
  @@index([schoolId])
  @@index([status])
}

enum SelectionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 2: Conduct / Behaviour Tracking ──────────────────────────

model StudentConduct {
  id              String        @id @default(cuid())
  studentId       String
  classArmId      String
  termId          String
  academicYearId  String
  schoolId        String
  punctuality     ConductRating @default(GOOD)
  attendance      ConductRating @default(GOOD)
  attentiveness   ConductRating @default(GOOD)
  neatness        ConductRating @default(GOOD)
  politeness      ConductRating @default(GOOD)
  honesty         ConductRating @default(GOOD)
  selfControl     ConductRating @default(GOOD)
  relationship    ConductRating @default(GOOD)
  initiative      ConductRating @default(GOOD)
  sports          ConductRating?
  handwriting     ConductRating?
  verbalFluency   ConductRating?
  otherTraits     Json?
  remarks         String?
  ratedBy         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  school School @relation("SchoolStudentConducts", fields: [schoolId], references: [id])

  @@unique([studentId, termId, academicYearId])
  @@index([classArmId])
  @@index([termId])
  @@index([studentId])
  @@index([schoolId])
}

enum ConductRating {
  EXCELLENT
  VERY_GOOD
  GOOD
  AVERAGE
  BELOW_AVERAGE
  POOR
}

// ─── Phase 3: Mark Audit Trail ──────────────────────────────────────

model MarkAuditLog {
  id               String      @id @default(cuid())
  markId           String
  studentId        String
  subjectId        String
  assessmentTypeId String
  termId           String
  schoolId         String
  previousScore    Float?
  newScore         Float?
  previousStatus   MarkStatus?
  newStatus        MarkStatus?
  changedBy        String
  changeReason     String?
  changedAt        DateTime    @default(now())

  school School @relation("SchoolMarkAuditLogs", fields: [schoolId], references: [id])

  @@index([markId])
  @@index([studentId])
  @@index([changedBy])
  @@index([changedAt])
  @@index([subjectId, termId])
  @@index([schoolId])
}

// ─── Phase 3: Academic Calendar Events ──────────────────────────────

model AcademicEvent {
  id             String            @id @default(cuid())
  schoolId       String
  academicYearId String?
  termId         String?
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  type           AcademicEventType
  isAllDay       Boolean           @default(true)
  color          String?
  createdBy      String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([academicYearId])
  @@index([startDate])
  @@index([schoolId, startDate])
}

enum AcademicEventType {
  EXAM_PERIOD
  HOLIDAY
  HALF_TERM
  PTA_MEETING
  SPORTS_DAY
  CULTURAL_EVENT
  ORIENTATION
  GRADUATION_CEREMONY
  REGISTRATION
  MARK_DEADLINE
  OTHER
}

// ─── Phase 4: Academic Interventions ────────────────────────────────

model AcademicIntervention {
  id             String             @id @default(cuid())
  studentId      String
  schoolId       String
  academicYearId String
  termId         String
  type           InterventionType
  title          String
  description    String?
  targetArea     String?
  startDate      DateTime
  endDate        DateTime?
  status         InterventionStatus @default(ACTIVE)
  outcome        String?
  assignedTo     String?
  createdBy      String
  notes          Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([studentId])
  @@index([schoolId])
  @@index([status])
  @@index([assignedTo])
}

enum InterventionType {
  ACADEMIC_SUPPORT
  TUTORING
  COUNSELING
  PARENT_CONFERENCE
  MENTORING
  REMEDIAL_CLASS
  OTHER_INTERVENTION
}

enum InterventionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

// ─── Phase 4: Co-Curricular Activities ──────────────────────────────

model CoCurricularActivity {
  id              String       @id @default(cuid())
  schoolId        String
  name            String
  type            ActivityType
  description     String?
  supervisorId    String?
  maxParticipants Int?
  status          Status       @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  participations StudentActivity[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([type])
}

model StudentActivity {
  id             String   @id @default(cuid())
  activityId     String
  studentId      String
  academicYearId String
  schoolId       String
  role           String?
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  achievements   String?
  status         Status   @default(ACTIVE)

  activity CoCurricularActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  school   School               @relation("SchoolStudentActivities", fields: [schoolId], references: [id])

  @@unique([activityId, studentId, academicYearId])
  @@index([activityId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([schoolId])
}

enum ActivityType {
  CLUB
  SPORT
  SOCIETY
  CULTURAL
  RELIGIOUS
  COMMUNITY_SERVICE
  OTHER_ACTIVITY
}

// ─── Phase 4: Academic Awards ───────────────────────────────────────

model AcademicAward {
  id             String    @id @default(cuid())
  studentId      String
  schoolId       String
  academicYearId String
  termId         String?
  type           AwardType
  title          String
  description    String?
  subjectId      String?
  awardedBy      String
  awardedAt      DateTime  @default(now())

  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([type])
}

enum AwardType {
  BEST_STUDENT
  BEST_IN_SUBJECT
  MOST_IMPROVED
  PERFECT_ATTENDANCE
  LEADERSHIP
  SPORTS_AWARD
  CUSTOM
}

// ─── Phase 4: Exam Seating Arrangement ──────────────────────────────

model ExamSeatingArrangement {
  id             String   @id @default(cuid())
  examScheduleId String
  studentId      String
  seatNumber     String
  roomId         String
  schoolId       String
  createdAt      DateTime @default(now())

  examSchedule ExamSchedule @relation(fields: [examScheduleId], references: [id], onDelete: Cascade)
  room         Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  school       School       @relation("SchoolExamSeatingArrangements", fields: [schoolId], references: [id])

  @@unique([examScheduleId, studentId])
  @@unique([examScheduleId, roomId, seatNumber])
  @@index([examScheduleId])
  @@index([studentId])
  @@index([schoolId])
}

// ─── Phase 5: Standards-Based Tracking ──────────────────────────────

model MarkStandardLink {
  id          String              @id @default(cuid())
  markId      String
  standardId  String
  schoolId    String
  proficiency StandardProficiency @default(DEVELOPING)

  school School @relation("SchoolMarkStandardLinks", fields: [schoolId], references: [id])

  @@unique([markId, standardId])
  @@index([markId])
  @@index([standardId])
  @@index([schoolId])
}

model StudentStandardMastery {
  id             String              @id @default(cuid())
  studentId      String
  standardId     String
  academicYearId String
  termId         String
  schoolId       String
  proficiency    StandardProficiency
  evidence       Json?
  computedAt     DateTime            @default(now())

  school School @relation("SchoolStudentStandardMasteries", fields: [schoolId], references: [id])

  @@unique([studentId, standardId, termId])
  @@index([studentId])
  @@index([standardId])
  @@index([studentId, academicYearId])
  @@index([schoolId])
}

enum StandardProficiency {
  NOT_YET
  DEVELOPING
  APPROACHING
  MEETING
  EXCEEDING
}

// ─── Phase 5: PTC (Parent-Teacher Conference) Scheduling ────────────

model PTCSession {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  title          String
  date           DateTime
  startTime      String
  endTime        String
  slotDuration   Int      @default(15)
  location       String?
  status         Status   @default(ACTIVE)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings PTCBooking[]

  @@index([schoolId])
  @@index([date])
}

model PTCBooking {
  id        String        @id @default(cuid())
  sessionId String
  teacherId String
  parentId  String
  studentId String
  schoolId  String
  timeSlot  String
  status    BookingStatus @default(CONFIRMED)
  notes     String?
  createdAt DateTime      @default(now())

  session PTCSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  school  School     @relation("SchoolPTCBookings", fields: [schoolId], references: [id])

  @@unique([sessionId, teacherId, timeSlot])
  @@index([sessionId])
  @@index([teacherId])
  @@index([parentId])
  @@index([studentId])
  @@index([schoolId])
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  PTC_COMPLETED
  NO_SHOW
}

// ─── Phase 5: Homework Module ───────────────────────────────────────

model Homework {
  id             String         @id @default(cuid())
  schoolId       String
  subjectId      String
  classArmId     String
  termId         String
  academicYearId String
  title          String
  description    String?
  dueDate        DateTime
  assignedBy     String
  maxScore       Float?
  status         HomeworkStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subject     Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([classArmId])
  @@index([subjectId])
  @@index([termId])
  @@index([dueDate])
  @@index([assignedBy])
}

model HomeworkSubmission {
  id          String                   @id @default(cuid())
  homeworkId  String
  studentId   String
  schoolId    String
  submittedAt DateTime                 @default(now())
  content     String?
  fileUrl     String?
  score       Float?
  feedback    String?
  gradedBy    String?
  gradedAt    DateTime?
  status      HomeworkSubmissionStatus  @default(SUBMITTED)

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  school   School   @relation("SchoolHomeworkSubmissions", fields: [schoolId], references: [id])

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
  @@index([studentId])
  @@index([schoolId])
  @@index([status])
}

enum HomeworkStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum HomeworkSubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
}

// ─── Phase 4: Item Bank (reusable question repository) ──────────────
// Teachers author questions once, tag them by subject, topic, difficulty and
// Bloom taxonomy level, and reuse them across Assessments, Homework, LMS
// quizzes, and practice papers. A Paper is a concrete selection of items
// (manual or generator-driven) that can be exported as a printable test.

model ItemBankQuestion {
  id              String                 @id @default(cuid())
  schoolId        String
  subjectId       String
  topic           String?
  stem            String                 // markdown allowed
  type            ItemBankQuestionType
  difficulty      ItemBankDifficulty     @default(MEDIUM)
  bloomLevel      BloomLevel             @default(UNDERSTAND)
  maxScore        Float                  @default(1)
  explanation     String?                // rationale shown after grading
  correctText     String?                // for SHORT_ANSWER / FILL_IN / ESSAY rubric
  metadata        Json?                  // free-form (images, rubric, etc)
  status          ItemBankQuestionStatus @default(DRAFT)
  authoredBy      String                 // userId
  reviewedBy      String?
  reviewedAt      DateTime?
  usageCount      Int                    @default(0)
  lastUsedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  choices      ItemBankChoice[]
  tagLinks     ItemBankQuestionTag[]
  paperLinks   ItemBankPaperQuestion[]
  responses    ItemBankResponse[]

  @@index([schoolId])
  @@index([subjectId])
  @@index([difficulty])
  @@index([status])
  @@index([bloomLevel])
  @@index([schoolId, subjectId, status])
}

model ItemBankChoice {
  id          String  @id @default(cuid())
  questionId  String
  schoolId    String
  text        String
  isCorrect   Boolean @default(false)
  order       Int     @default(0)
  explanation String?

  question ItemBankQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([schoolId])
}

model ItemBankTag {
  id        String  @id @default(cuid())
  schoolId  String
  name      String
  color     String?

  questions ItemBankQuestionTag[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ItemBankQuestionTag {
  questionId String
  tagId      String
  schoolId   String

  question ItemBankQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      ItemBankTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
  @@index([schoolId])
}

model ItemBankPaper {
  id             String              @id @default(cuid())
  schoolId       String
  title          String
  subjectId      String
  yearGroup      Int?
  termId         String?
  academicYearId String?
  totalScore     Float               @default(0)
  durationMins   Int?
  instructions   String?
  status         ItemBankPaperStatus @default(DRAFT)
  generatorSpec  Json?               // parameters used to auto-generate (difficulty mix, blueprint)
  createdBy      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  questions   ItemBankPaperQuestion[]
  submissions ItemBankSubmission[]

  @@index([schoolId])
  @@index([subjectId])
  @@index([status])
}

model ItemBankPaperQuestion {
  id         String  @id @default(cuid())
  paperId    String
  questionId String
  schoolId   String
  order      Int
  scoreOverride Float?   // optional per-paper score weight

  paper    ItemBankPaper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question ItemBankQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([paperId, questionId])
  @@unique([paperId, order])
  @@index([paperId])
  @@index([questionId])
  @@index([schoolId])
}

enum ItemBankQuestionType {
  MULTIPLE_CHOICE
  MULTI_SELECT
  TRUE_FALSE
  SHORT_ANSWER
  FILL_IN_BLANK
  ESSAY
  MATCHING
  NUMERIC
}

enum ItemBankDifficulty {
  EASY
  MEDIUM
  HARD
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum ItemBankQuestionStatus {
  DRAFT
  UNDER_REVIEW
  PUBLISHED
  RETIRED
}

enum ItemBankPaperStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

// ─── Phase 4 follow-through: Grader ─────────────────────────────────
// A submission is one student's attempt at a paper. Responses are per
// question and carry both the raw answer and the grader's verdict. Auto-
// gradable types (MC, MS, TF, NUMERIC, FILL_IN_BLANK, SHORT_ANSWER with
// exact-match) get scored on submit; ESSAY/MATCHING responses stay in
// NEEDS_REVIEW until a teacher grades them manually.

model ItemBankSubmission {
  id             String                    @id @default(cuid())
  schoolId       String
  paperId        String
  studentId      String
  attemptedAt    DateTime                  @default(now())
  submittedAt    DateTime?
  timeSpentSecs  Int?
  status         ItemBankSubmissionStatus  @default(IN_PROGRESS)
  rawScore       Float                     @default(0)
  maxScore       Float                     @default(0)
  autoGraded     Boolean                   @default(false)
  needsReview    Boolean                   @default(false)
  gradedBy       String?
  gradedAt       DateTime?

  paper     ItemBankPaper        @relation(fields: [paperId], references: [id], onDelete: Cascade)
  responses ItemBankResponse[]

  @@unique([paperId, studentId, attemptedAt])
  @@index([schoolId])
  @@index([paperId])
  @@index([studentId])
  @@index([status])
}

model ItemBankResponse {
  id             String                 @id @default(cuid())
  submissionId   String
  questionId     String
  schoolId       String
  // Raw answer — shape depends on question type. For MC, selected choice id.
  // For MULTI_SELECT, array of choice ids. For SHORT_ANSWER / NUMERIC /
  // FILL_IN_BLANK, a string.
  rawAnswer      Json
  correct        Boolean?               // null = not-yet-graded
  awardedScore   Float                  @default(0)
  maxScore       Float                  @default(1)
  feedback       String?
  verdict        ItemBankResponseVerdict @default(NEEDS_REVIEW)
  gradedAt       DateTime?
  gradedBy       String?

  submission ItemBankSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   ItemBankQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
  @@index([schoolId])
}

enum ItemBankSubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  PARTIALLY_GRADED
  VOIDED
}

enum ItemBankResponseVerdict {
  CORRECT
  INCORRECT
  PARTIAL
  NEEDS_REVIEW
}
