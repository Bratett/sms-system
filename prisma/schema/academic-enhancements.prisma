// ─── Phase 2: Student Elective Selection ────────────────────────────

model StudentSubjectSelection {
  id               String          @id @default(cuid())
  studentId        String
  subjectId        String
  academicYearId   String
  status           SelectionStatus @default(PENDING)
  selectedAt       DateTime        @default(now())
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, academicYearId])
  @@index([studentId])
  @@index([subjectId])
  @@index([academicYearId])
  @@index([status])
}

enum SelectionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 2: Conduct / Behaviour Tracking ──────────────────────────

model StudentConduct {
  id              String        @id @default(cuid())
  studentId       String
  classArmId      String
  termId          String
  academicYearId  String
  punctuality     ConductRating @default(GOOD)
  attendance      ConductRating @default(GOOD)
  attentiveness   ConductRating @default(GOOD)
  neatness        ConductRating @default(GOOD)
  politeness      ConductRating @default(GOOD)
  honesty         ConductRating @default(GOOD)
  selfControl     ConductRating @default(GOOD)
  relationship    ConductRating @default(GOOD)
  initiative      ConductRating @default(GOOD)
  sports          ConductRating?
  handwriting     ConductRating?
  verbalFluency   ConductRating?
  otherTraits     Json?
  remarks         String?
  ratedBy         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([studentId, termId, academicYearId])
  @@index([classArmId])
  @@index([termId])
  @@index([studentId])
}

enum ConductRating {
  EXCELLENT
  VERY_GOOD
  GOOD
  AVERAGE
  BELOW_AVERAGE
  POOR
}

// ─── Phase 3: Mark Audit Trail ──────────────────────────────────────

model MarkAuditLog {
  id               String      @id @default(cuid())
  markId           String
  studentId        String
  subjectId        String
  assessmentTypeId String
  termId           String
  previousScore    Float?
  newScore         Float?
  previousStatus   MarkStatus?
  newStatus        MarkStatus?
  changedBy        String
  changeReason     String?
  changedAt        DateTime    @default(now())

  @@index([markId])
  @@index([studentId])
  @@index([changedBy])
  @@index([changedAt])
  @@index([subjectId, termId])
}

// ─── Phase 3: Academic Calendar Events ──────────────────────────────

model AcademicEvent {
  id             String            @id @default(cuid())
  schoolId       String
  academicYearId String?
  termId         String?
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  type           AcademicEventType
  isAllDay       Boolean           @default(true)
  color          String?
  createdBy      String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([academicYearId])
  @@index([startDate])
  @@index([schoolId, startDate])
}

enum AcademicEventType {
  EXAM_PERIOD
  HOLIDAY
  HALF_TERM
  PTA_MEETING
  SPORTS_DAY
  CULTURAL_EVENT
  ORIENTATION
  GRADUATION_CEREMONY
  REGISTRATION
  MARK_DEADLINE
  OTHER
}

// ─── Phase 4: Academic Interventions ────────────────────────────────

model AcademicIntervention {
  id             String             @id @default(cuid())
  studentId      String
  schoolId       String
  academicYearId String
  termId         String
  type           InterventionType
  title          String
  description    String?
  targetArea     String?
  startDate      DateTime
  endDate        DateTime?
  status         InterventionStatus @default(ACTIVE)
  outcome        String?
  assignedTo     String?
  createdBy      String
  notes          Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([studentId])
  @@index([schoolId])
  @@index([status])
  @@index([assignedTo])
}

enum InterventionType {
  ACADEMIC_SUPPORT
  TUTORING
  COUNSELING
  PARENT_CONFERENCE
  MENTORING
  REMEDIAL_CLASS
  OTHER_INTERVENTION
}

enum InterventionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

// ─── Phase 4: Co-Curricular Activities ──────────────────────────────

model CoCurricularActivity {
  id              String       @id @default(cuid())
  schoolId        String
  name            String
  type            ActivityType
  description     String?
  supervisorId    String?
  maxParticipants Int?
  status          Status       @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  participations StudentActivity[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([type])
}

model StudentActivity {
  id             String   @id @default(cuid())
  activityId     String
  studentId      String
  academicYearId String
  role           String?
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  achievements   String?
  status         Status   @default(ACTIVE)

  activity CoCurricularActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, studentId, academicYearId])
  @@index([activityId])
  @@index([studentId])
  @@index([academicYearId])
}

enum ActivityType {
  CLUB
  SPORT
  SOCIETY
  CULTURAL
  RELIGIOUS
  COMMUNITY_SERVICE
  OTHER_ACTIVITY
}

// ─── Phase 4: Academic Awards ───────────────────────────────────────

model AcademicAward {
  id             String    @id @default(cuid())
  studentId      String
  schoolId       String
  academicYearId String
  termId         String?
  type           AwardType
  title          String
  description    String?
  subjectId      String?
  awardedBy      String
  awardedAt      DateTime  @default(now())

  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([type])
}

enum AwardType {
  BEST_STUDENT
  BEST_IN_SUBJECT
  MOST_IMPROVED
  PERFECT_ATTENDANCE
  LEADERSHIP
  SPORTS_AWARD
  CUSTOM
}

// ─── Phase 4: Exam Seating Arrangement ──────────────────────────────

model ExamSeatingArrangement {
  id             String   @id @default(cuid())
  examScheduleId String
  studentId      String
  seatNumber     String
  roomId         String
  createdAt      DateTime @default(now())

  examSchedule ExamSchedule @relation(fields: [examScheduleId], references: [id], onDelete: Cascade)
  room         Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([examScheduleId, studentId])
  @@unique([examScheduleId, roomId, seatNumber])
  @@index([examScheduleId])
  @@index([studentId])
}

// ─── Phase 5: Standards-Based Tracking ──────────────────────────────

model MarkStandardLink {
  id          String              @id @default(cuid())
  markId      String
  standardId  String
  proficiency StandardProficiency @default(DEVELOPING)

  @@unique([markId, standardId])
  @@index([markId])
  @@index([standardId])
}

model StudentStandardMastery {
  id             String              @id @default(cuid())
  studentId      String
  standardId     String
  academicYearId String
  termId         String
  proficiency    StandardProficiency
  evidence       Json?
  computedAt     DateTime            @default(now())

  @@unique([studentId, standardId, termId])
  @@index([studentId])
  @@index([standardId])
  @@index([studentId, academicYearId])
}

enum StandardProficiency {
  NOT_YET
  DEVELOPING
  APPROACHING
  MEETING
  EXCEEDING
}

// ─── Phase 5: PTC (Parent-Teacher Conference) Scheduling ────────────

model PTCSession {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  title          String
  date           DateTime
  startTime      String
  endTime        String
  slotDuration   Int      @default(15)
  location       String?
  status         Status   @default(ACTIVE)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings PTCBooking[]

  @@index([schoolId])
  @@index([date])
}

model PTCBooking {
  id        String        @id @default(cuid())
  sessionId String
  teacherId String
  parentId  String
  studentId String
  timeSlot  String
  status    BookingStatus @default(CONFIRMED)
  notes     String?
  createdAt DateTime      @default(now())

  session PTCSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, teacherId, timeSlot])
  @@index([sessionId])
  @@index([teacherId])
  @@index([parentId])
  @@index([studentId])
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  PTC_COMPLETED
  NO_SHOW
}

// ─── Phase 5: Homework Module ───────────────────────────────────────

model Homework {
  id             String         @id @default(cuid())
  schoolId       String
  subjectId      String
  classArmId     String
  termId         String
  academicYearId String
  title          String
  description    String?
  dueDate        DateTime
  assignedBy     String
  maxScore       Float?
  status         HomeworkStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subject     Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([classArmId])
  @@index([subjectId])
  @@index([termId])
  @@index([dueDate])
  @@index([assignedBy])
}

model HomeworkSubmission {
  id          String                   @id @default(cuid())
  homeworkId  String
  studentId   String
  submittedAt DateTime                 @default(now())
  content     String?
  fileUrl     String?
  score       Float?
  feedback    String?
  gradedBy    String?
  gradedAt    DateTime?
  status      HomeworkSubmissionStatus  @default(SUBMITTED)

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
  @@index([studentId])
  @@index([status])
}

enum HomeworkStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum HomeworkSubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
}
