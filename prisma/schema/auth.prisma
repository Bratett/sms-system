model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles                UserRole[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  userSchools              UserSchool[]
  invigilatorExamSchedules ExamSchedule[]  @relation("InvigilatorExamSchedules")
  teacherThreads           MessageThread[]     @relation("TeacherThreads")
  lockedMessageThreads     MessageThread[]     @relation("MessageThreadLockedBy")
  authoredMessages         Message[]           @relation("AuthoredMessages")
  messageThreadReads       MessageThreadRead[] @relation("MessageThreadReads")
  reportedMessages         MessageReport[]     @relation("MessageReportReporter")
  resolvedMessageReports   MessageReport[]     @relation("MessageReportResolver")
  submittedExcuses     ExcuseRequest[]     @relation("SubmittedExcuses")
  reviewedExcuses      ExcuseRequest[]     @relation("ReviewedExcuses")
  submittedDisclosures MedicalDisclosure[] @relation("SubmittedDisclosures")
  reviewedDisclosures  MedicalDisclosure[] @relation("ReviewedDisclosures")

  @@index([email])
  @@index([username])
  @@index([status])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([code])
  @@index([module])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model UserSchool {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

model ApiKey {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  keyHash     String    @unique
  prefix      String
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([prefix])
  @@index([schoolId])
  @@index([isActive])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
