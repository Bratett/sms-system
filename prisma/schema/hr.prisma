model Staff {
  id                      String    @id @default(cuid())
  schoolId                String
  userId                  String?   @unique
  staffId                 String    @unique // Auto: STF/YYYY/NNNN
  firstName               String
  lastName                String
  otherNames              String?
  dateOfBirth             DateTime?
  gender                  Gender
  phone                   String
  email                   String?
  ghanaCardNumber         String?   // Encrypted via AES-256-GCM
  ssnitNumber             String?   // Encrypted via AES-256-GCM
  tinNumber               String?   // Encrypted via AES-256-GCM
  qualifications          Json?     // Array of {degree, institution, year}
  specialization          String?
  dateOfFirstAppointment  DateTime?
  dateOfPostingToSchool   DateTime?
  staffType               StaffType @default(TEACHING)
  photoUrl                String?
  address                 String?
  region                  String?
  status                  StaffStatus @default(ACTIVE)
  deletedAt               DateTime?   // Soft delete
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  employments Employment[]
  leaveRequests LeaveRequest[]
  disciplinaryRecords StaffDisciplinary[]
  performanceNotes PerformanceNote[]
  attendanceRecords StaffAttendance[]
  contracts StaffContract[]
  loans StaffLoan[]
  promotions StaffPromotion[]
  teacherLicences TeacherLicence[]

  @@index([schoolId])
  @@index([staffId])
  @@index([staffType])
  @@index([status])
  @@index([deletedAt])
}

model Employment {
  id              String          @id @default(cuid())
  staffId         String
  schoolId        String
  position        String
  rank            String?
  departmentId    String?
  startDate       DateTime
  endDate         DateTime?
  appointmentType AppointmentType @default(PERMANENT)
  salaryGrade     String?
  status          EmploymentStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  school School @relation("SchoolEmployment", fields: [schoolId], references: [id])

  @@index([staffId])
  @@index([departmentId])
  @@index([status])
  @@index([schoolId])
}

model LeaveType {
  id              String  @id @default(cuid())
  schoolId        String
  name            String
  defaultDays     Int     @default(0)
  requiresApproval Boolean @default(true)
  applicableGender String? // null = all, MALE, FEMALE
  status          Status  @default(ACTIVE)
  createdAt       DateTime @default(now())

  leaveBalances  LeaveBalance[]
  leaveRequests  LeaveRequest[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model LeaveBalance {
  id             String @id @default(cuid())
  staffId        String
  leaveTypeId    String
  schoolId       String
  academicYearId String
  totalDays      Int
  usedDays       Int    @default(0)
  remainingDays  Int

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  school    School    @relation("SchoolLeaveBalance", fields: [schoolId], references: [id])

  @@unique([staffId, leaveTypeId, academicYearId])
  @@index([staffId])
  @@index([academicYearId])
  @@index([schoolId])
}

model LeaveRequest {
  id            String      @id @default(cuid())
  staffId       String
  leaveTypeId   String
  schoolId      String
  startDate     DateTime
  endDate       DateTime
  daysRequested Int
  reason        String?
  status        LeaveRequestStatus @default(PENDING)
  appliedAt     DateTime    @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?

  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  school    School    @relation("SchoolLeaveRequest", fields: [schoolId], references: [id])

  @@index([staffId])
  @@index([leaveTypeId])
  @@index([status])
  @@index([staffId, status])
  @@index([schoolId])
}

model PayrollPeriod {
  id       String        @id @default(cuid())
  schoolId String
  month    Int
  year     Int
  status   PayrollStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  entries PayrollEntry[]

  @@unique([schoolId, month, year])
  @@index([schoolId])
}

model PayrollEntry {
  id              String @id @default(cuid())
  payrollPeriodId String
  staffId         String
  schoolId        String
  basicSalary     Decimal @db.Decimal(18, 2)
  totalAllowances Decimal @default(0) @db.Decimal(18, 2)
  totalDeductions Decimal @default(0) @db.Decimal(18, 2)
  netPay          Decimal @db.Decimal(18, 2)
  details         Json?  // Breakdown: {allowances: [{name, amount}], deductions: [{name, amount}]}
  createdAt       DateTime @default(now())

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  school        School        @relation("SchoolPayrollEntry", fields: [schoolId], references: [id])

  @@unique([payrollPeriodId, staffId])
  @@index([payrollPeriodId])
  @@index([staffId])
  @@index([schoolId])
}

model Allowance {
  id       String @id @default(cuid())
  schoolId String
  name     String
  type     AllowanceType @default(FIXED)
  amount   Decimal @db.Decimal(18, 2)
  status   Status @default(ACTIVE)
  createdAt DateTime @default(now())

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Deduction {
  id          String @id @default(cuid())
  schoolId    String
  name        String
  type        AllowanceType @default(FIXED)
  amount      Decimal @db.Decimal(18, 2)
  isStatutory Boolean @default(false)
  status      Status  @default(ACTIVE)
  createdAt   DateTime @default(now())

  @@unique([schoolId, name])
  @@index([schoolId])
}

enum StaffType {
  TEACHING
  NON_TEACHING
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RETIRED
  TRANSFERRED
}

enum AppointmentType {
  PERMANENT
  CONTRACT
  NATIONAL_SERVICE
  VOLUNTEER
}

enum EmploymentStatus {
  ACTIVE
  ENDED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum AllowanceType {
  FIXED
  PERCENTAGE
}

// ─── Staff Disciplinary & Performance ──────────────────────────────

model StaffDisciplinary {
  id          String   @id @default(cuid())
  schoolId    String
  staffId     String
  reportedBy  String   // User ID
  date        DateTime
  type        String   // MISCONDUCT, NEGLIGENCE, INSUBORDINATION, ABSENTEEISM, OTHER
  description String
  severity    String   @default("MINOR") // MINOR, MODERATE, MAJOR, CRITICAL
  sanction    String?
  status      String   @default("REPORTED") // REPORTED, INVESTIGATING, RESOLVED, DISMISSED
  resolvedBy  String?
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([staffId])
  @@index([status])
}

model PerformanceNote {
  id             String   @id @default(cuid())
  schoolId       String
  staffId        String
  reviewerId     String   // User ID of reviewer
  period         String   // e.g., "Term 1 2024/2025"
  academicYearId String?
  rating         Int?     // 1-5 scale
  strengths      String?
  areasForImprovement String?
  goals          String?
  comments       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([staffId])
  @@index([academicYearId])
}

// ─── Public Holiday Calendar ──────────────────────────────────

model PublicHoliday {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  date      DateTime
  recurring Boolean  @default(false) // If true, repeats annually (day/month only)
  createdAt DateTime @default(now())

  @@unique([schoolId, date])
  @@index([schoolId])
  @@index([date])
}

// ─── Staff Attendance ─────────────────────────────────────────

model StaffAttendance {
  id         String                @id @default(cuid())
  schoolId   String
  staffId    String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  status     StaffAttendanceStatus @default(PRESENT)
  source     String                @default("MANUAL") // MANUAL, BIOMETRIC, SYSTEM
  remarks    String?
  recordedBy String?               // User ID
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([schoolId, date])
  @@index([staffId])
  @@index([status])
}

enum StaffAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

// ─── Staff Contracts ──────────────────────────────────────────

model StaffContract {
  id             String         @id @default(cuid())
  schoolId       String
  staffId        String
  contractNumber String?
  type           String         // PERMANENT, FIXED_TERM, PROBATION, NATIONAL_SERVICE
  startDate      DateTime
  endDate        DateTime?
  renewalDate    DateTime?
  terms          String?        // Free-text terms summary
  documentId     String?        // Link to Document for the contract PDF
  status         ContractStatus @default(ACTIVE)
  createdBy      String         // User ID
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([staffId])
  @@index([endDate])
  @@index([status])
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  RENEWED
  TERMINATED
}

// ─── Staff Loans & Advances ──────────────────────────────────

model StaffLoan {
  id               String     @id @default(cuid())
  schoolId         String
  staffId          String
  loanNumber       String     @unique // Auto: LN/YYYY/NNNN
  type             String     // SALARY_ADVANCE, PERSONAL_LOAN, EMERGENCY_LOAN
  amount           Decimal    @db.Decimal(18, 2)
  interestRate     Decimal    @default(0) @db.Decimal(5, 2)
  totalRepayment   Decimal    @db.Decimal(18, 2)
  monthlyDeduction Decimal    @db.Decimal(18, 2)
  tenure           Int        // months
  remainingBalance Decimal    @db.Decimal(18, 2)
  status           LoanStatus @default(PENDING)
  approvedBy       String?    // User ID
  approvedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  staff      Staff           @relation(fields: [staffId], references: [id], onDelete: Cascade)
  repayments LoanRepayment[]

  @@index([schoolId])
  @@index([staffId])
  @@index([status])
}

model LoanRepayment {
  id              String   @id @default(cuid())
  loanId          String
  schoolId        String
  payrollPeriodId String?  // Null if manual payment
  amount          Decimal  @db.Decimal(18, 2)
  date            DateTime @default(now())
  method          String   @default("PAYROLL_DEDUCTION") // PAYROLL_DEDUCTION, MANUAL

  loan   StaffLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  school School    @relation("SchoolLoanRepayment", fields: [schoolId], references: [id])

  @@index([loanId])
  @@index([payrollPeriodId])
  @@index([schoolId])
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  FULLY_PAID
  DEFAULTED
  CANCELLED
}

// ─── Staff Promotions ─────────────────────────────────────────

model StaffPromotion {
  id               String   @id @default(cuid())
  schoolId         String
  staffId          String
  effectiveDate    DateTime
  previousRank     String?
  newRank          String
  previousGrade    String?
  newGrade         String?
  previousSalary   Decimal? @db.Decimal(18, 2)
  newSalary        Decimal? @db.Decimal(18, 2)
  reason           String?
  approvedBy       String   // User ID
  letterDocumentId String?  // Link to Document for the promotion letter
  createdAt        DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([staffId])
}

// ─── Statutory tax / deduction tables (country-level, not tenant-scoped) ───
// These are reference data shared across tenants; no RLS policy. Effective-
// dated so rate changes land as new rows without losing history.
// See src/lib/payroll/tax-tables.ts for the cached reader.

model TaxTable {
  id             String            @id @default(cuid())
  country        String            // ISO alpha-2: "GH", "NG", "KE"
  name           String            // "PAYE (Income Tax)", "SSNIT (Tier 1)", …
  type           TaxDeductionType
  orderIndex     Int               @default(0)  // rendering/application order
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  // Flat-rate deductions (e.g. SSNIT, Pension, NSSF) — percent values.
  employeeRate   Decimal?          @db.Decimal(8, 4)
  employerRate   Decimal?          @db.Decimal(8, 4)
  // NSSF-style cap on the base amount deductions apply to.
  ceilingAmount  Decimal?          @db.Decimal(18, 2)
  // Bracket-based deductions (PAYE). Stored as JSON:
  // [{ min: number, max: number | null, rate: number }]
  brackets       Json?
  // Nigeria PAYE annualises the gross before bracketing; Kenya subtracts a
  // flat personal relief after computing bracketed tax.
  annualized     Boolean           @default(false)
  relief         Decimal?          @db.Decimal(18, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([country, name, effectiveFrom])
  @@index([country, effectiveFrom])
}

enum TaxDeductionType {
  INCOME_TAX
  SOCIAL_SECURITY
  PENSION
  OTHER
}

// ─── Phase 3: NTC teacher licensure ──────────────────────────────────
// Teachers in Ghanaian public schools must hold a valid National Teaching
// Council (NTC) licence. Licences carry a category (e.g. Beginner / Proficient)
// and a renewal date. Expiry alerts are fired by a daily worker that mirrors
// the contract-expiry pattern.

model TeacherLicence {
  id           String              @id @default(cuid())
  schoolId     String
  staffId      String
  ntcNumber    String              @unique
  category     String              // e.g. "BEGINNER", "PROFICIENT", "EXPERT"
  issuedAt     DateTime
  expiresAt    DateTime
  status       TeacherLicenceStatus @default(ACTIVE)
  // Optional link to a Document row holding the scanned licence certificate.
  documentId   String?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([staffId])
  @@index([expiresAt])
  @@index([status])
}

enum TeacherLicenceStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}
