model School {
  id                        String         @id @default(cuid())
  name                      String
  motto                     String?
  address                   String?
  region                    String?
  district                  String?
  town                      String?
  phone                     String?
  email                     String?
  website                   String?
  logoUrl                   String?
  type                      SchoolType     @default(DAY_BOARDING)
  category                  SchoolCategory @default(PUBLIC)
  ghanaEducationServiceCode String?
  postalAddress             String?
  // Ghana statutory registration identifiers. Surfaced on payroll returns,
  // GRA filings and GETFund disbursement reports — nullable so pre-existing
  // rows don't need a backfill pass.
  tin                       String?
  ssnitEmployerNumber       String?
  getFundCode               String?
  graVatTin                 String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  academicYears       AcademicYear[]
  departments         Department[]
  programmes          Programme[]
  houses              House[]
  gradingScales       GradingScale[]
  rooms               Room[]
  periods             Period[]
  examSchedules       ExamSchedule[]
  userSchools         UserSchool[]
  academicEvents      AcademicEvent[]
  attendanceRegisters AttendanceRegister[]
  attendancePolicies  AttendancePolicy[]
  attendanceAlerts    AttendanceAlert[]
  eventAttendances    EventAttendance[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  terms               Term[]
  gradeDefinitions    GradeDefinition[]

  // Academic
  classArms                 ClassArm[]                 @relation("SchoolClassArm")
  enrollments               Enrollment[]               @relation("SchoolEnrollment")
  marks                     Mark[]                     @relation("SchoolMark")
  terminalResults           TerminalResult[]           @relation("SchoolTerminalResult")
  subjectResults            SubjectResult[]            @relation("SchoolSubjectResult")
  annualResults             AnnualResult[]             @relation("SchoolAnnualResult")
  subjectAnnualResults      SubjectAnnualResult[]      @relation("SchoolSubjectAnnualResult")
  programmeSubjects         ProgrammeSubject[]         @relation("SchoolProgrammeSubject")
  teacherSubjectAssignments TeacherSubjectAssignment[] @relation("SchoolTeacherSubjectAssignment")

  // Academic enhancements
  studentSubjectSelections StudentSubjectSelection[] @relation("SchoolStudentSubjectSelections")
  studentConducts          StudentConduct[]          @relation("SchoolStudentConducts")
  markAuditLogs            MarkAuditLog[]            @relation("SchoolMarkAuditLogs")
  studentActivities        StudentActivity[]         @relation("SchoolStudentActivities")
  examSeatingArrangements  ExamSeatingArrangement[]  @relation("SchoolExamSeatingArrangements")
  markStandardLinks        MarkStandardLink[]        @relation("SchoolMarkStandardLinks")
  studentStandardMasteries StudentStandardMastery[]  @relation("SchoolStudentStandardMasteries")
  ptcBookings              PTCBooking[]              @relation("SchoolPTCBookings")
  homeworkSubmissions      HomeworkSubmission[]      @relation("SchoolHomeworkSubmissions")

  // Student
  guardians           Guardian[]           @relation("SchoolGuardian")
  studentGuardians    StudentGuardian[]    @relation("SchoolStudentGuardian")
  studentHouses       StudentHouse[]       @relation("SchoolStudentHouse")
  admissionDocuments  AdmissionDocument[]  @relation("SchoolAdmissionDocument")
  admissionInterviews AdmissionInterview[] @relation("SchoolAdmissionInterview")
  admissionDecisions  AdmissionDecision[]  @relation("SchoolAdmissionDecision")
  admissionAppeals    AdmissionAppeal[]    @relation("SchoolAdmissionAppeal")
  admissionOffers     AdmissionOffer[]     @relation("SchoolAdmissionOffer")

  // Finance
  feeItems             FeeItem[]             @relation("SchoolFeeItem")
  studentBills         StudentBill[]         @relation("SchoolStudentBill")
  studentBillItems     StudentBillItem[]     @relation("SchoolStudentBillItem")
  payments             Payment[]             @relation("SchoolPayment")
  receipts             Receipt[]             @relation("SchoolReceipt")
  studentScholarships  StudentScholarship[]  @relation("SchoolStudentScholarship")
  paymentReversals     PaymentReversal[]     @relation("SchoolPaymentReversal")
  feeTemplateItems     FeeTemplateItem[]     @relation("SchoolFeeTemplateItem")
  installmentSchedules InstallmentSchedule[] @relation("SchoolInstallmentSchedule")
  studentInstallments  StudentInstallment[]  @relation("SchoolStudentInstallment")
  appliedPenalties     AppliedPenalty[]      @relation("SchoolAppliedPenalty")
  subsidyDisbursements SubsidyDisbursement[] @relation("SchoolSubsidyDisbursement")
  donorFundAllocations DonorFundAllocation[] @relation("SchoolDonorFundAllocation")
  bankStatementEntries BankStatementEntry[]  @relation("SchoolBankStatementEntry")

  // Accounting
  journalEntries          JournalEntry[]           @relation("SchoolJournalEntry")
  pettyCashTransactions   PettyCashTransaction[]   @relation("SchoolPettyCashTransaction")
  pettyCashReplenishments PettyCashReplenishment[] @relation("SchoolPettyCashReplenishment")
  budgetLines             BudgetLine[]             @relation("SchoolBudgetLine")
  expenseClaimItems       ExpenseClaimItem[]       @relation("SchoolExpenseClaimItem")

  // HR
  employments    Employment[]    @relation("SchoolEmployment")
  leaveBalances  LeaveBalance[]  @relation("SchoolLeaveBalance")
  leaveRequests  LeaveRequest[]  @relation("SchoolLeaveRequest")
  payrollEntries PayrollEntry[]  @relation("SchoolPayrollEntry")
  loanRepayments LoanRepayment[] @relation("SchoolLoanRepayment")

  // Boarding
  dormitories     Dormitory[]      @relation("SchoolDormitory")
  beds            Bed[]            @relation("SchoolBed")
  bedAllocations  BedAllocation[]  @relation("SchoolBedAllocation")
  exeats          Exeat[]          @relation("SchoolExeat")
  exeatApprovals  ExeatApproval[]  @relation("SchoolExeatApproval")
  rollCalls       RollCall[]       @relation("SchoolRollCall")
  rollCallRecords RollCallRecord[] @relation("SchoolRollCallRecord")
  medicationLogs  MedicationLog[]  @relation("SchoolMedicationLog")

  // Attendance
  attendanceRecords AttendanceRecord[] @relation("SchoolAttendanceRecords")

  // Communication
  graduationRecords GraduationRecord[] @relation("SchoolGraduationRecords")

  // LMS
  lessons               Lesson[]               @relation("SchoolLessons")
  lmsAssignments        LmsAssignment[]        @relation("SchoolLmsAssignments")
  assignmentSubmissions AssignmentSubmission[] @relation("SchoolAssignmentSubmissions")
  lessonProgress        LessonProgress[]       @relation("SchoolLessonProgress")
  courseEnrollments     CourseEnrollment[]     @relation("SchoolCourseEnrollments")
  quizQuestions         QuizQuestion[]         @relation("SchoolQuizQuestions")

  // Library
  bookIssues BookIssue[] @relation("SchoolBookIssues")

  // Transport
  routeStops        RouteStop[]        @relation("SchoolRouteStops")
  studentTransports StudentTransport[] @relation("SchoolStudentTransports")

  // Workflow engine
  workflowInstances   WorkflowInstance[]   @relation("SchoolWorkflowInstance")
  workflowTransitions WorkflowTransition[] @relation("SchoolWorkflowTransition")

  // Promotion
  promotionRuns PromotionRun[] @relation("SchoolPromotionRun")

  // Student documents
  documentTypes    DocumentType[]    @relation("SchoolDocumentType")
  studentDocuments StudentDocument[] @relation("SchoolStudentDocument")

  reportCardPdfCaches ReportCardPdfCache[] @relation("SchoolReportCardCache")
  pdfJobs             PdfJob[]             @relation("SchoolPdfJob")
}

model AcademicYear {
  id        String             @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  status    AcademicYearStatus @default(UPCOMING)
  isCurrent Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms         Term[]
  examSchedules ExamSchedule[]

  sourcePromotionRuns PromotionRun[] @relation("SourcePromotionYear")
  targetPromotionRuns PromotionRun[] @relation("TargetPromotionYear")

  classes       Class[]        @relation("ClassAcademicYear")
  enrollments   Enrollment[]   @relation("EnrollmentAcademicYear")
  studentHouses StudentHouse[] @relation("StudentHouseAcademicYear")

  @@index([schoolId])
  @@index([isCurrent])
  @@index([schoolId, isCurrent])
}

model Term {
  id             String     @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  termNumber     Int
  startDate      DateTime
  endDate        DateTime
  status         TermStatus @default(UPCOMING)
  isCurrent      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  school        School         @relation(fields: [schoolId], references: [id])
  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examSchedules ExamSchedule[]

  reportCardPdfCaches ReportCardPdfCache[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([isCurrent])
  @@index([academicYearId, isCurrent])
}

model Department {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  programmes Programme[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Programme {
  id           String   @id @default(cuid())
  schoolId     String
  departmentId String?
  name         String
  code         String?
  description  String?
  duration     Int      @default(3)
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  classes    Class[]     @relation("ClassProgramme")

  @@unique([schoolId, name])
  @@index([schoolId])
}

model House {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  color       String?
  motto       String?
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentHouses StudentHouse[] @relation("StudentHouseHouse")

  @@unique([schoolId, name])
  @@index([schoolId])
}

model GradingScale {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradeDefinitions GradeDefinition[]

  @@index([schoolId])
  @@index([isDefault])
}

model GradeDefinition {
  id             String @id @default(cuid())
  schoolId       String
  gradingScaleId String
  grade          String
  minScore       Float
  maxScore       Float
  interpretation String
  gradePoint     Float  @default(0)

  school       School       @relation(fields: [schoolId], references: [id])
  gradingScale GradingScale @relation(fields: [gradingScaleId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([gradingScaleId])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  module      String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([module])
}

enum SchoolType {
  DAY
  BOARDING
  DAY_BOARDING
}

enum SchoolCategory {
  PUBLIC
  PRIVATE
}

enum AcademicYearStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TermStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum Status {
  ACTIVE
  INACTIVE
}
