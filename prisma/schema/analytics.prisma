model StudentRiskProfile {
  id              String   @id @default(cuid())
  studentId       String
  schoolId        String
  academicYearId  String
  termId          String
  riskScore       Float    // 0-100, higher = more at risk
  riskLevel       RiskLevel
  factors         Json     // Array of contributing factors
  recommendations Json     // Array of recommended interventions
  performanceTrend String? // IMPROVING, STABLE, DECLINING
  predictedAverage Float?  // Predicted next-term average
  computedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([studentId, academicYearId, termId])
  @@index([schoolId])
  @@index([studentId])
  @@index([riskLevel])
  @@index([schoolId, riskLevel])
}

model AnalyticsSnapshot {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  type           SnapshotType
  data           Json
  computedAt     DateTime @default(now())

  @@unique([schoolId, academicYearId, termId, type])
  @@index([schoolId])
  @@index([type])
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum SnapshotType {
  ACADEMIC_SUMMARY
  ATTENDANCE_SUMMARY
  FINANCE_SUMMARY
  ENROLLMENT_TRENDS
  SUBJECT_PERFORMANCE
  COHORT_ANALYSIS
}
