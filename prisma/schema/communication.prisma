model Announcement {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  content     String
  targetType  String    @default("all") // all, class, programme, house, specific
  targetIds   Json? // array of IDs if targeted
  priority    String    @default("normal") // low, normal, high, urgent
  publishedAt DateTime?
  expiresAt   DateTime?
  createdBy   String
  status      String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
  @@index([status])
}

model SmsLog {
  id                String    @id @default(cuid())
  schoolId          String
  recipientPhone    String
  recipientName     String?
  message           String
  status            String    @default("QUEUED") // QUEUED, SENT, DELIVERED, FAILED
  provider          String?
  providerMessageId String?
  sentAt            DateTime?
  cost              Decimal?  @db.Decimal(18, 4)
  createdAt         DateTime  @default(now())

  @@index([schoolId])
  @@index([status])
}

model DisciplinaryIncident {
  id          String    @id @default(cuid())
  schoolId    String
  studentId   String
  reportedBy  String
  date        DateTime
  type        String // e.g., "Fighting", "Truancy", "Vandalism", "Disobedience"
  description String
  severity    String    @default("MINOR") // MINOR, MODERATE, MAJOR, CRITICAL
  sanction    String?
  status      String    @default("REPORTED") // REPORTED, INVESTIGATING, RESOLVED, DISMISSED
  resolvedBy  String?
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

// ─── Counseling & Welfare ────────────────────────────────────────────

model CounselingRecord {
  id             String    @id @default(cuid())
  schoolId       String
  studentId      String
  counselorId    String // User ID of guidance counsellor
  sessionDate    DateTime
  type           String // ACADEMIC, PERSONAL, CAREER, BEHAVIORAL, FAMILY, OTHER
  summary        String
  actionPlan     String?
  followUpDate   DateTime?
  status         String    @default("OPEN") // OPEN, FOLLOW_UP, CLOSED
  isConfidential Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([counselorId])
}

model WelfareNote {
  id               String   @id @default(cuid())
  schoolId         String
  studentId        String
  createdBy        String // User ID
  date             DateTime
  category         String // HEALTH, NUTRITION, HOUSING, FINANCIAL, EMOTIONAL, SAFETY, OTHER
  description      String
  actionTaken      String?
  followUpRequired Boolean  @default(false)
  status           String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
}

model Commendation {
  id             String   @id @default(cuid())
  schoolId       String
  studentId      String
  awardedBy      String // User ID
  date           DateTime
  type           String // ACADEMIC_EXCELLENCE, SPORTS, LEADERSHIP, COMMUNITY_SERVICE, BEST_STUDENT, IMPROVEMENT, OTHER
  title          String
  description    String?
  termId         String?
  academicYearId String?
  createdAt      DateTime @default(now())

  @@index([schoolId])
  @@index([studentId])
}

// ─── Graduation ──────────────────────────────────────────────────────

model GraduationBatch {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  ceremonyDate   DateTime?
  status         String    @default("PENDING") // PENDING, COMPLETED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  records GraduationRecord[]

  @@index([schoolId])
}

model GraduationRecord {
  id                String   @id @default(cuid())
  graduationBatchId String
  studentId         String
  schoolId          String
  certificateNumber String?
  honours           String? // First Class, Second Class, Pass
  status            String   @default("PENDING") // PENDING, CONFIRMED
  createdAt         DateTime @default(now())

  batch  GraduationBatch @relation(fields: [graduationBatchId], references: [id], onDelete: Cascade)
  school School          @relation("SchoolGraduationRecords", fields: [schoolId], references: [id])

  @@unique([graduationBatchId, studentId])
  @@index([graduationBatchId])
  @@index([studentId])
  @@index([schoolId])
}

// ─── Alumni Profiles ─────────────────────────────────────────────────

model AlumniProfile {
  id               String   @id @default(cuid())
  studentId        String   @unique // link to Student record
  schoolId         String
  graduationYear   Int
  email            String?
  phone            String?
  address          String?
  currentEmployer  String?
  currentPosition  String?
  industry         String?
  highestEducation String? // e.g., "BSc Computer Science, University of Ghana"
  linkedinUrl      String?
  bio              String?
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([schoolId])
  @@index([graduationYear])
}

// ─── Phase 2: DB-backed notification templates + user preferences ────

model NotificationTemplate {
  id        String              @id @default(cuid())
  schoolId  String? // null = global default; school-scoped override when set
  key       String // matches NOTIFICATION_EVENTS keys (e.g. "fee_reminder")
  channel   NotificationChannel
  locale    String              @default("en") // "en", "tw", "ga"
  subject   String? // nullable for SMS/WhatsApp
  body      String // {{var}} placeholders
  variables Json? // documented variable list for the editor
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([schoolId, key, channel, locale])
  @@index([schoolId])
  @@index([key, channel])
}

model NotificationPreference {
  id        String                @id @default(cuid())
  userId    String
  eventKey  String // NOTIFICATION_EVENTS key; "*" means all
  channels  NotificationChannel[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, eventKey])
  @@index([userId])
}

enum NotificationChannel {
  IN_APP
  SMS
  EMAIL
  WHATSAPP
  PUSH
}

// ─── Phase 2: Scheduled communication campaigns ─────────────────────

model CommunicationCampaign {
  id            String                      @id @default(cuid())
  schoolId      String
  name          String
  templateId    String? // NotificationTemplate.id (optional for ad-hoc)
  channel       NotificationChannel
  subject       String?
  body          String
  // JSON description of the recipient audience; resolved at dispatch time.
  // Example shape: { kind: "CLASS_ARM", classArmId: "..." } or
  //                { kind: "BOARDING_STUDENTS", hostelId: "..." }.
  audienceQuery Json
  scheduledAt   DateTime
  status        CommunicationCampaignStatus @default(SCHEDULED)
  dispatchedAt  DateTime?
  sentCount     Int                         @default(0)
  failedCount   Int                         @default(0)
  createdBy     String // userId
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([schoolId])
  @@index([status, scheduledAt])
}

enum CommunicationCampaignStatus {
  SCHEDULED
  DISPATCHING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Messaging: Parent ↔ Teacher threads ─────────────────────────────

model MessageThread {
  id            String              @id @default(cuid())
  schoolId      String
  studentId     String
  teacherUserId String
  status        MessageThreadStatus @default(ACTIVE)
  lockedAt      DateTime?
  lockedBy      String?
  lockReason    String?
  lastMessageAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  student  Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school   School              @relation("SchoolMessageThread", fields: [schoolId], references: [id])
  teacher  User                @relation("TeacherThreads", fields: [teacherUserId], references: [id])
  messages Message[]
  reads    MessageThreadRead[]

  @@index([studentId, teacherUserId])
  @@index([schoolId, status])
  @@index([teacherUserId, status])
  @@index([studentId])
  @@index([lastMessageAt])
}

enum MessageThreadStatus {
  ACTIVE
  ARCHIVED
}

model Message {
  id             String   @id @default(cuid())
  threadId       String
  authorUserId   String
  body           String
  attachmentKey  String?
  attachmentName String?
  attachmentSize Int?
  attachmentMime String?
  systemNote     Boolean  @default(false)
  createdAt      DateTime @default(now())

  thread  MessageThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User            @relation("AuthoredMessages", fields: [authorUserId], references: [id])
  reports MessageReport[]

  @@index([threadId, createdAt])
  @@index([authorUserId])
}

model MessageThreadRead {
  id         String   @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model MessageReport {
  id               String              @id @default(cuid())
  messageId        String
  reportedByUserId String
  reason           String
  status           MessageReportStatus @default(PENDING)
  createdAt        DateTime            @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([messageId])
}

enum MessageReportStatus {
  PENDING
  DISMISSED
  ACTIONED
}
