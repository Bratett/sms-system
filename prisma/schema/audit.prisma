model AuditLog {
  id           String      @id @default(cuid())
  schoolId     String?
  timestamp    DateTime    @default(now())
  userId       String
  userRole     String?
  action       AuditAction
  entity       String
  entityId     String?
  module       String
  description  String
  previousData Json?
  newData      Json?
  ipAddress    String?
  userAgent    String?
  metadata     Json?

  school School? @relation(fields: [schoolId], references: [id])
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([userId])
  @@index([entity])
  @@index([module])
  @@index([timestamp])
  @@index([action])
}

model Notification {
  id        String           @id @default(cuid())
  schoolId  String?
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  school School? @relation(fields: [schoolId], references: [id])
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([userId, isRead])
  @@index([createdAt])
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  PUBLISH
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}
