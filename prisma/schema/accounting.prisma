// ─── Chart of Accounts ────────────────────────────────────────────

model AccountCategory {
  id        String      @id @default(cuid())
  schoolId  String
  name      String
  type      AccountType
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  accounts Account[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Account {
  id              String      @id @default(cuid())
  schoolId        String
  categoryId      String
  parentId        String?
  code            String
  name            String
  description     String?
  normalBalance   BalanceSide
  isSystemAccount Boolean     @default(false)
  isActive        Boolean     @default(true)
  isBudgetary     Boolean     @default(false) // true = encumbrance/budgetary control accounts (off-statement)
  isContra        Boolean     @default(false) // contra-asset (e.g., Allowance for Doubtful Receivables) or contra-liability
  currentBalance  Decimal     @default(0) @db.Decimal(18, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category AccountCategory @relation(fields: [categoryId], references: [id])
  parent   Account?        @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[]       @relation("AccountHierarchy")
  entries  JournalEntry[]  @relation("AccountEntries")

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([categoryId])
  @@index([parentId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  BUDGETARY // IPSAS budgetary control — encumbrances/reserves (not part of proprietary statements)
}

enum BalanceSide {
  DEBIT
  CREDIT
}

// ─── Funds (IPSAS Fund Accounting) ────────────────────────────────

model Fund {
  id           String   @id @default(cuid())
  schoolId     String
  code         String // e.g., "GEN", "RF-SCI", "CAP", "END"
  name         String
  type         FundType
  parentFundId String?
  description  String?
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false) // one General Fund per school flagged as default
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent   Fund?          @relation("FundHierarchy", fields: [parentFundId], references: [id])
  children Fund[]         @relation("FundHierarchy")
  entries  JournalEntry[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([type])
}

enum FundType {
  GENERAL
  RESTRICTED
  CAPITAL
  DONOR
  ENDOWMENT
}

// ─── Fiscal Periods ───────────────────────────────────────────────

model FiscalPeriod {
  id           String             @id @default(cuid())
  schoolId     String
  name         String // "FY 2026", "FY 2026 Q1"
  fiscalYearId String? // null for top-level year, set for sub-periods (quarters/months)
  startDate    DateTime
  endDate      DateTime
  status       FiscalPeriodStatus @default(OPEN)
  isFiscalYear Boolean            @default(false) // true = top-level year period eligible for year-end close
  closedBy     String?
  closedAt     DateTime?
  closingNotes String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  fiscalYear   FiscalPeriod?        @relation("FiscalYearPeriods", fields: [fiscalYearId], references: [id])
  subPeriods   FiscalPeriod[]       @relation("FiscalYearPeriods")
  transactions JournalTransaction[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([status])
  @@index([startDate, endDate])
}

enum FiscalPeriodStatus {
  OPEN
  SOFT_CLOSED // only adjusting entries allowed (PERIOD_ADJUST permission)
  CLOSED
}

// ─── General Ledger & Journal Entries ─────────────────────────────

model JournalTransaction {
  id                String        @id @default(cuid())
  schoolId          String
  transactionNumber String        @unique // JRN/YYYY/NNNN
  date              DateTime
  description       String
  referenceType     String? // "Payment", "Expense", "PettyCash", "Payroll", "Billing", "Waiver", "Scholarship", "Penalty", "Subsidy", "DonorFund", "Encumbrance", "FiscalClose", "Impairment", "Reversal"
  referenceId       String?
  fiscalPeriodId    String?
  isAutoGenerated   Boolean       @default(false)
  isAdjusting       Boolean       @default(false)
  isClosing         Boolean       @default(false)
  createdBy         String
  postedBy          String?
  postedAt          DateTime?
  reversedBy        String?
  reversedAt        DateTime?
  reversalOfId      String? // if this txn is a reversal, id of the original txn
  status            JournalStatus @default(DRAFT)
  createdAt         DateTime      @default(now())

  fiscalPeriod FiscalPeriod?        @relation(fields: [fiscalPeriodId], references: [id])
  entries      JournalEntry[]
  reversalOf   JournalTransaction?  @relation("JournalTxnReversal", fields: [reversalOfId], references: [id])
  reversals    JournalTransaction[] @relation("JournalTxnReversal")

  @@index([schoolId])
  @@index([date])
  @@index([status])
  @@index([referenceType, referenceId])
  @@index([fiscalPeriodId])
}

model JournalEntry {
  id                   String      @id @default(cuid())
  journalTransactionId String
  schoolId             String
  accountId            String
  fundId               String? // null = General Fund
  side                 BalanceSide
  amount               Decimal     @db.Decimal(18, 2)
  narration            String?
  lineOrder            Int         @default(0)

  journalTransaction JournalTransaction @relation(fields: [journalTransactionId], references: [id], onDelete: Cascade)
  account            Account            @relation("AccountEntries", fields: [accountId], references: [id])
  fund               Fund?              @relation(fields: [fundId], references: [id])
  school             School             @relation("SchoolJournalEntry", fields: [schoolId], references: [id])

  @@index([journalTransactionId])
  @@index([accountId])
  @@index([schoolId])
  @@index([fundId])
  @@index([side])
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

// ─── Expense Management ───────────────────────────────────────────

model ExpenseCategory {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String?
  accountId String? // link to Chart of Accounts
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent      ExpenseCategory?  @relation("ExpenseCategoryHierarchy", fields: [parentId], references: [id])
  children    ExpenseCategory[] @relation("ExpenseCategoryHierarchy")
  expenses    Expense[]
  budgetLines BudgetLine[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Expense {
  id                 String         @id @default(cuid())
  schoolId           String
  expenseCategoryId  String
  description        String
  amount             Decimal        @db.Decimal(18, 2)
  date               DateTime
  payee              String?
  referenceNumber    String?
  paymentMethod      PaymentMethod?
  receiptUrl         String?
  departmentId       String?
  termId             String?
  fundId             String? // IPSAS fund segregation
  budgetCommitmentId String? // set when expense liquidates a budget commitment
  status             ExpenseStatus  @default(PENDING)
  submittedBy        String
  approvedBy         String?
  approvedAt         DateTime?
  paidAt             DateTime?
  accrualJournalId   String? // Dr Expense / Cr AP at approval
  paymentJournalId   String? // Dr AP / Cr Cash at payment
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])

  @@index([schoolId])
  @@index([expenseCategoryId])
  @@index([status])
  @@index([date])
  @@index([departmentId])
  @@index([budgetCommitmentId])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

// ─── Petty Cash ───────────────────────────────────────────────────

model PettyCashFund {
  id              String   @id @default(cuid())
  schoolId        String
  name            String
  custodianId     String
  authorizedLimit Decimal  @db.Decimal(18, 2)
  currentBalance  Decimal  @default(0) @db.Decimal(18, 2)
  accountId       String? // chart-of-accounts petty-cash account (1141)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions   PettyCashTransaction[]
  replenishments PettyCashReplenishment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([custodianId])
}

model PettyCashTransaction {
  id                   String        @id @default(cuid())
  pettyCashFundId      String
  schoolId             String
  type                 PettyCashType
  amount               Decimal       @db.Decimal(18, 2)
  description          String
  receiptNumber        String?
  receiptUrl           String?
  recordedBy           String
  expenseCategoryId    String?
  journalTransactionId String?
  date                 DateTime
  createdAt            DateTime      @default(now())

  pettyCashFund PettyCashFund @relation(fields: [pettyCashFundId], references: [id], onDelete: Cascade)
  school        School        @relation("SchoolPettyCashTransaction", fields: [schoolId], references: [id])

  @@index([pettyCashFundId])
  @@index([date])
  @@index([schoolId])
}

model PettyCashReplenishment {
  id                   String              @id @default(cuid())
  pettyCashFundId      String
  schoolId             String
  amount               Decimal             @db.Decimal(18, 2)
  requestedBy          String
  approvedBy           String?
  journalTransactionId String?
  status               ReplenishmentStatus @default(PENDING)
  requestedAt          DateTime            @default(now())
  approvedAt           DateTime?

  pettyCashFund PettyCashFund @relation(fields: [pettyCashFundId], references: [id], onDelete: Cascade)
  school        School        @relation("SchoolPettyCashReplenishment", fields: [schoolId], references: [id])

  @@index([pettyCashFundId])
  @@index([status])
  @@index([schoolId])
}

enum PettyCashType {
  DISBURSEMENT
  REPLENISHMENT
  ADJUSTMENT
}

enum ReplenishmentStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

// ─── Budget Management ────────────────────────────────────────────

model Budget {
  id             String       @id @default(cuid())
  schoolId       String
  name           String
  academicYearId String
  termId         String?
  fiscalPeriodId String? // IPSAS 24 — linked to fiscal period for budget-vs-actual
  fundId         String? // budget may be scoped to a fund
  totalAmount    Decimal      @db.Decimal(18, 2)
  originalAmount Decimal?     @db.Decimal(18, 2) // IPSAS 24 — original budget before revisions
  status         BudgetStatus @default(DRAFT)
  createdBy      String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines BudgetLine[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([status])
}

model BudgetLine {
  id                String  @id @default(cuid())
  budgetId          String
  schoolId          String
  expenseCategoryId String
  departmentId      String?
  allocatedAmount   Decimal @db.Decimal(18, 2)
  originalAmount    Decimal @default(0) @db.Decimal(18, 2) // IPSAS 24 — before revisions
  committedAmount   Decimal @default(0) @db.Decimal(18, 2) // encumbrances outstanding
  spentAmount       Decimal @default(0) @db.Decimal(18, 2) // actual expenses paid
  description       String?

  budget            Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenseCategory   ExpenseCategory    @relation(fields: [expenseCategoryId], references: [id])
  school            School             @relation("SchoolBudgetLine", fields: [schoolId], references: [id])
  budgetCommitments BudgetCommitment[]
  encumbrances      Encumbrance[]

  @@unique([budgetId, expenseCategoryId, departmentId])
  @@index([budgetId])
  @@index([schoolId])
}

enum BudgetStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
}

// ─── Expense Claims ───────────────────────────────────────────────

model ExpenseClaim {
  id                   String             @id @default(cuid())
  schoolId             String
  claimantId           String
  description          String
  totalAmount          Decimal            @db.Decimal(18, 2)
  status               ExpenseClaimStatus @default(SUBMITTED)
  submittedAt          DateTime           @default(now())
  approvedBy           String?
  approvedAt           DateTime?
  paidAt               DateTime?
  journalTransactionId String?

  items ExpenseClaimItem[]

  @@index([schoolId])
  @@index([claimantId])
  @@index([status])
}

model ExpenseClaimItem {
  id                String   @id @default(cuid())
  expenseClaimId    String
  schoolId          String
  description       String
  amount            Decimal  @db.Decimal(18, 2)
  date              DateTime
  receiptUrl        String?
  expenseCategoryId String?

  expenseClaim ExpenseClaim @relation(fields: [expenseClaimId], references: [id], onDelete: Cascade)
  school       School       @relation("SchoolExpenseClaimItem", fields: [schoolId], references: [id])

  @@index([expenseClaimId])
  @@index([schoolId])
}

enum ExpenseClaimStatus {
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

// ─── Budgetary Commitments & Encumbrances (IPSAS budgetary control) ─

// Commitment = a board-approved obligation against a budget line that reserves
// budget authority BEFORE an actual expense is recognized. Creates an encumbrance
// journal (Dr Encumbrance / Cr Reserve for Encumbrance) on approval and liquidates
// (reverses) it when invoiced as a real Expense.
model BudgetCommitment {
  id                   String                 @id @default(cuid())
  schoolId             String
  commitmentNumber     String // COM/YYYY/NNNN
  vendorName           String
  vendorContact        String?
  budgetLineId         String?
  fundId               String?
  description          String?
  totalAmount          Decimal                @db.Decimal(18, 2)
  liquidatedAmount     Decimal                @default(0) @db.Decimal(18, 2)
  currency             String                 @default("GHS")
  commitmentDate       DateTime
  expectedDate         DateTime?
  status               BudgetCommitmentStatus @default(DRAFT)
  approvedBy           String?
  approvedAt           DateTime?
  fulfilledAt          DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  encumbranceJournalId String? // initial Dr Encumbrance / Cr Reserve journal
  createdBy            String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  budgetLine   BudgetLine?            @relation(fields: [budgetLineId], references: [id])
  lines        BudgetCommitmentLine[]
  encumbrances Encumbrance[]

  @@unique([schoolId, commitmentNumber])
  @@index([schoolId])
  @@index([status])
  @@index([budgetLineId])
}

model BudgetCommitmentLine {
  id                 String  @id @default(cuid())
  budgetCommitmentId String
  schoolId           String
  description        String
  quantity           Decimal @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal @db.Decimal(18, 4)
  amount             Decimal @db.Decimal(18, 2)
  expenseCategoryId  String?

  budgetCommitment BudgetCommitment @relation(fields: [budgetCommitmentId], references: [id], onDelete: Cascade)

  @@index([budgetCommitmentId])
  @@index([schoolId])
}

enum BudgetCommitmentStatus {
  DRAFT
  APPROVED
  PARTIALLY_LIQUIDATED
  LIQUIDATED
  CANCELLED
}

model Encumbrance {
  id                   String            @id @default(cuid())
  schoolId             String
  budgetCommitmentId   String
  budgetLineId         String?
  amount               Decimal           @db.Decimal(18, 2)
  status               EncumbranceStatus @default(ACTIVE)
  journalTransactionId String? // Dr 9100 Encumbrance / Cr 9200 Reserve
  liquidationJournalId String? // reversal journal when liquidated
  createdAt            DateTime          @default(now())
  liquidatedAt         DateTime?
  cancelledAt          DateTime?

  budgetCommitment BudgetCommitment @relation(fields: [budgetCommitmentId], references: [id], onDelete: Cascade)
  budgetLine       BudgetLine?      @relation(fields: [budgetLineId], references: [id])

  @@index([schoolId])
  @@index([budgetCommitmentId])
  @@index([budgetLineId])
  @@index([status])
}

enum EncumbranceStatus {
  ACTIVE
  LIQUIDATED
  CANCELLED
}

// ─── Financial Report Snapshots ───────────────────────────────────

model FinancialReport {
  id          String              @id @default(cuid())
  schoolId    String
  reportType  FinancialReportType
  periodStart DateTime
  periodEnd   DateTime
  fundId      String? // optional fund segment
  generatedBy String
  generatedAt DateTime            @default(now())
  data        Json
  fileUrl     String?
  status      ReportStatus        @default(DRAFT)

  @@index([schoolId])
  @@index([reportType])
  @@index([generatedAt])
}

enum FinancialReportType {
  BALANCE_SHEET
  INCOME_STATEMENT
  CASH_FLOW
  TRIAL_BALANCE
  GENERAL_LEDGER
  BUDGET_VS_ACTUAL
  BOARD_SUMMARY
  GRA_TAX_RETURN
  CUSTOM
  STATEMENT_OF_FINANCIAL_POSITION // IPSAS renaming of Balance Sheet
  STATEMENT_OF_FINANCIAL_PERFORMANCE // IPSAS renaming of Income Statement
  STATEMENT_OF_CHANGES_IN_NET_ASSETS // IPSAS 1
  STATEMENT_OF_BUDGET_VS_ACTUAL // IPSAS 24
  RECEIVABLES_AGING
  FUND_STATEMENT
  CASH_FLOW_DIRECT
}

enum ReportStatus {
  DRAFT
  FINALIZED
}

// ─── Tax Records (GRA Compliance) ─────────────────────────────────

model TaxRecord {
  id              String    @id @default(cuid())
  schoolId        String
  taxType         TaxType
  period          String
  amount          Decimal   @db.Decimal(18, 2)
  dueDate         DateTime
  paidAmount      Decimal   @default(0) @db.Decimal(18, 2)
  paidDate        DateTime?
  referenceNumber String?
  status          TaxStatus @default(PENDING)
  filedBy         String?
  filedAt         DateTime?
  createdAt       DateTime  @default(now())

  @@index([schoolId])
  @@index([status])
  @@index([dueDate])
  @@index([taxType])
}

enum TaxType {
  PAYE
  VAT
  WITHHOLDING
  CORPORATE_TAX
  SSNIT
}

enum TaxStatus {
  PENDING
  FILED
  PAID
  OVERDUE
}

// ─── Custom Report Definitions ────────────────────────────────────

model CustomReportDefinition {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  definition  Json
  createdBy   String
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([createdBy])
}

// ─── Receivables Impairment (IPSAS 29/41) ─────────────────────────

model ImpairmentRun {
  id                   String   @id @default(cuid())
  schoolId             String
  asOfDate             DateTime
  totalReceivables     Decimal  @db.Decimal(18, 2)
  totalAllowance       Decimal  @db.Decimal(18, 2) // expected credit loss
  journalTransactionId String?
  generatedBy          String
  generatedAt          DateTime @default(now())
  buckets              Json // aging breakdown {b0_30, b31_60, b61_90, b91_180, b180_plus, rates, allowance per bucket}

  @@index([schoolId])
  @@index([asOfDate])
}
