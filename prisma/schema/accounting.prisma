// ─── Phase 3: Chart of Accounts ──────────────────────────────────

model AccountCategory {
  id        String      @id @default(cuid())
  schoolId  String
  name      String // Assets, Liabilities, Equity, Revenue, Expenses
  type      AccountType
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  accounts Account[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Account {
  id              String      @id @default(cuid())
  schoolId        String
  categoryId      String
  parentId        String? // for sub-accounts
  code            String // e.g., "1000", "2100", "4000"
  name            String
  description     String?
  normalBalance   BalanceSide // DEBIT or CREDIT
  isSystemAccount Boolean     @default(false)
  isActive        Boolean     @default(true)
  currentBalance  Decimal     @default(0) @db.Decimal(18, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category      AccountCategory @relation(fields: [categoryId], references: [id])
  parent        Account?        @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]       @relation("AccountHierarchy")
  debitEntries  JournalEntry[]  @relation("DebitAccount")
  creditEntries JournalEntry[]  @relation("CreditAccount")

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([categoryId])
  @@index([parentId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BalanceSide {
  DEBIT
  CREDIT
}

// ─── Phase 3: General Ledger & Journal Entries ───────────────────

model JournalTransaction {
  id                String        @id @default(cuid())
  schoolId          String
  transactionNumber String        @unique // JRN/YYYY/NNNN
  date              DateTime
  description       String
  referenceType     String? // "Payment", "Expense", "PettyCash", "Payroll"
  referenceId       String?
  isAutoGenerated   Boolean       @default(false)
  createdBy         String
  approvedBy        String?
  approvedAt        DateTime?
  status            JournalStatus @default(DRAFT)
  createdAt         DateTime      @default(now())

  entries JournalEntry[]

  @@index([schoolId])
  @@index([date])
  @@index([status])
  @@index([referenceType, referenceId])
}

model JournalEntry {
  id                   String  @id @default(cuid())
  journalTransactionId String
  schoolId             String
  debitAccountId       String
  creditAccountId      String
  amount               Decimal @db.Decimal(18, 2)
  narration            String?

  journalTransaction JournalTransaction @relation(fields: [journalTransactionId], references: [id], onDelete: Cascade)
  debitAccount       Account            @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount      Account            @relation("CreditAccount", fields: [creditAccountId], references: [id])
  school             School             @relation("SchoolJournalEntry", fields: [schoolId], references: [id])

  @@index([journalTransactionId])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([schoolId])
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

// ─── Phase 3: Expense Management ─────────────────────────────────

model ExpenseCategory {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String?
  accountId String? // link to Chart of Accounts
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent      ExpenseCategory?  @relation("ExpenseCategoryHierarchy", fields: [parentId], references: [id])
  children    ExpenseCategory[] @relation("ExpenseCategoryHierarchy")
  expenses    Expense[]
  budgetLines BudgetLine[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Expense {
  id                   String         @id @default(cuid())
  schoolId             String
  expenseCategoryId    String
  description          String
  amount               Decimal        @db.Decimal(18, 2)
  date                 DateTime
  payee                String?
  referenceNumber      String?
  paymentMethod        PaymentMethod?
  receiptUrl           String?
  departmentId         String?
  termId               String?
  status               ExpenseStatus  @default(PENDING)
  submittedBy          String // userId
  approvedBy           String?
  approvedAt           DateTime?
  journalTransactionId String? // link to auto-generated journal entry
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])

  @@index([schoolId])
  @@index([expenseCategoryId])
  @@index([status])
  @@index([date])
  @@index([departmentId])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

// ─── Phase 3: Petty Cash ─────────────────────────────────────────

model PettyCashFund {
  id              String   @id @default(cuid())
  schoolId        String
  name            String
  custodianId     String // userId
  authorizedLimit Decimal  @db.Decimal(18, 2)
  currentBalance  Decimal  @default(0) @db.Decimal(18, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions   PettyCashTransaction[]
  replenishments PettyCashReplenishment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([custodianId])
}

model PettyCashTransaction {
  id                String        @id @default(cuid())
  pettyCashFundId   String
  schoolId          String
  type              PettyCashType
  amount            Decimal       @db.Decimal(18, 2)
  description       String
  receiptNumber     String?
  receiptUrl        String?
  recordedBy        String // userId
  expenseCategoryId String?
  date              DateTime
  createdAt         DateTime      @default(now())

  pettyCashFund PettyCashFund @relation(fields: [pettyCashFundId], references: [id], onDelete: Cascade)
  school        School        @relation("SchoolPettyCashTransaction", fields: [schoolId], references: [id])

  @@index([pettyCashFundId])
  @@index([date])
  @@index([schoolId])
}

model PettyCashReplenishment {
  id              String              @id @default(cuid())
  pettyCashFundId String
  schoolId        String
  amount          Decimal             @db.Decimal(18, 2)
  requestedBy     String
  approvedBy      String?
  status          ReplenishmentStatus @default(PENDING)
  requestedAt     DateTime            @default(now())
  approvedAt      DateTime?

  pettyCashFund PettyCashFund @relation(fields: [pettyCashFundId], references: [id], onDelete: Cascade)
  school        School        @relation("SchoolPettyCashReplenishment", fields: [schoolId], references: [id])

  @@index([pettyCashFundId])
  @@index([status])
  @@index([schoolId])
}

enum PettyCashType {
  DISBURSEMENT
  REPLENISHMENT
  ADJUSTMENT
}

enum ReplenishmentStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

// ─── Phase 3: Budget Management ──────────────────────────────────

model Budget {
  id             String       @id @default(cuid())
  schoolId       String
  name           String
  academicYearId String
  termId         String? // null = annual budget
  totalAmount    Decimal      @db.Decimal(18, 2)
  status         BudgetStatus @default(DRAFT)
  createdBy      String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines BudgetLine[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([status])
}

model BudgetLine {
  id                String  @id @default(cuid())
  budgetId          String
  schoolId          String
  expenseCategoryId String
  departmentId      String?
  allocatedAmount   Decimal @db.Decimal(18, 2)
  spentAmount       Decimal @default(0) @db.Decimal(18, 2)
  description       String?

  budget          Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])
  school          School          @relation("SchoolBudgetLine", fields: [schoolId], references: [id])

  @@unique([budgetId, expenseCategoryId, departmentId])
  @@index([budgetId])
  @@index([schoolId])
}

enum BudgetStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
}

// ─── Phase 3: Expense Claims ─────────────────────────────────────

model ExpenseClaim {
  id          String             @id @default(cuid())
  schoolId    String
  claimantId  String // userId or staffId
  description String
  totalAmount Decimal            @db.Decimal(18, 2)
  status      ExpenseClaimStatus @default(SUBMITTED)
  submittedAt DateTime           @default(now())
  approvedBy  String?
  approvedAt  DateTime?
  paidAt      DateTime?

  items ExpenseClaimItem[]

  @@index([schoolId])
  @@index([claimantId])
  @@index([status])
}

model ExpenseClaimItem {
  id                String   @id @default(cuid())
  expenseClaimId    String
  schoolId          String
  description       String
  amount            Decimal  @db.Decimal(18, 2)
  date              DateTime
  receiptUrl        String?
  expenseCategoryId String?

  expenseClaim ExpenseClaim @relation(fields: [expenseClaimId], references: [id], onDelete: Cascade)
  school       School       @relation("SchoolExpenseClaimItem", fields: [schoolId], references: [id])

  @@index([expenseClaimId])
  @@index([schoolId])
}

enum ExpenseClaimStatus {
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

// ─── Phase 4: Financial Report Snapshots ─────────────────────────

model FinancialReport {
  id          String              @id @default(cuid())
  schoolId    String
  reportType  FinancialReportType
  periodStart DateTime
  periodEnd   DateTime
  generatedBy String
  generatedAt DateTime            @default(now())
  data        Json // Structured report data
  fileUrl     String? // PDF export URL
  status      ReportStatus        @default(DRAFT)

  @@index([schoolId])
  @@index([reportType])
  @@index([generatedAt])
}

enum FinancialReportType {
  BALANCE_SHEET
  INCOME_STATEMENT
  CASH_FLOW
  TRIAL_BALANCE
  GENERAL_LEDGER
  BUDGET_VS_ACTUAL
  BOARD_SUMMARY
  GRA_TAX_RETURN
  CUSTOM
}

enum ReportStatus {
  DRAFT
  FINALIZED
}

// ─── Phase 4: Tax Records (GRA Compliance) ───────────────────────

model TaxRecord {
  id              String    @id @default(cuid())
  schoolId        String
  taxType         TaxType
  period          String // "2026-Q1", "2026-03"
  amount          Decimal   @db.Decimal(18, 2)
  dueDate         DateTime
  paidAmount      Decimal   @default(0) @db.Decimal(18, 2)
  paidDate        DateTime?
  referenceNumber String? // GRA filing reference
  status          TaxStatus @default(PENDING)
  filedBy         String?
  filedAt         DateTime?
  createdAt       DateTime  @default(now())

  @@index([schoolId])
  @@index([status])
  @@index([dueDate])
  @@index([taxType])
}

enum TaxType {
  PAYE
  VAT
  WITHHOLDING
  CORPORATE_TAX
  SSNIT
}

enum TaxStatus {
  PENDING
  FILED
  PAID
  OVERDUE
}

// ─── Phase 4: Custom Report Definitions ──────────────────────────

model CustomReportDefinition {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  definition  Json // Report structure: columns, filters, grouping, formulas
  createdBy   String
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([createdBy])
}
