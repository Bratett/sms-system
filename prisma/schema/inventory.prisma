model Store {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  managerId   String?  // staffId or userId
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items StoreItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ItemCategory {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  createdAt   DateTime @default(now())

  items StoreItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model StoreItem {
  id           String   @id @default(cuid())
  storeId      String
  categoryId   String?
  name         String
  code         String?
  unit         String   @default("pcs") // pcs, kg, liters, boxes, etc.
  quantity     Int      @default(0)
  reorderLevel Int      @default(0)
  unitPrice    Float    @default(0)
  description  String?
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category  ItemCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([categoryId])
  @@index([quantity])
  @@index([status])
}

model StockMovement {
  id               String        @id @default(cuid())
  storeItemId      String
  type             MovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  referenceType    String?       // purchaseOrder, issuance, return, adjustment
  referenceId      String?
  issuedTo         String?       // department, staff, hostel, class
  conductedBy      String        // userId
  conductedAt      DateTime      @default(now())

  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([storeItemId])
  @@index([conductedAt])
  @@index([type])
  @@index([referenceId])
}

model Supplier {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model PurchaseRequest {
  id          String              @id @default(cuid())
  storeId     String
  requestedBy String              // userId
  reason      String?
  status      PurchaseRequestStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  approvedBy  String?
  approvedAt  DateTime?

  items PurchaseRequestItem[]

  @@index([storeId])
  @@index([status])
}

model PurchaseRequestItem {
  id                String @id @default(cuid())
  purchaseRequestId String
  storeItemId       String
  quantityRequested Int
  estimatedUnitPrice Float?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model PurchaseOrder {
  id                String            @id @default(cuid())
  purchaseRequestId String?
  supplierId        String
  orderNumber       String            @unique // PO/YYYY/NNNN
  totalAmount       Float             @default(0)
  status            PurchaseOrderStatus @default(DRAFT)
  orderedBy         String            // userId
  orderedAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]
  goodsReceived GoodsReceived[]

  @@index([supplierId])
  @@index([status])
  @@index([supplierId, status])
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  storeItemId     String
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  storeItem     StoreItem     @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model GoodsReceived {
  id              String   @id @default(cuid())
  purchaseOrderId String
  receivedBy      String   // userId
  receivedAt      DateTime @default(now())
  notes           String?

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items         GoodsReceivedItem[]

  @@index([purchaseOrderId])
}

model GoodsReceivedItem {
  id               String @id @default(cuid())
  goodsReceivedId  String
  storeItemId      String
  quantityReceived Int
  condition        String? // Good, Damaged, Expired

  goodsReceived GoodsReceived @relation(fields: [goodsReceivedId], references: [id], onDelete: Cascade)

  @@index([goodsReceivedId])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  DAMAGED
  EXPIRED
  RETURNED
}

enum PurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}
