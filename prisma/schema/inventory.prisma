model Store {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  managerId   String?  // staffId or userId
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items StoreItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ItemCategory {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  createdAt   DateTime @default(now())

  items StoreItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model StoreItem {
  id           String   @id @default(cuid())
  storeId      String
  categoryId   String?
  name         String
  code         String?
  unit         String   @default("pcs") // pcs, kg, liters, boxes, etc.
  quantity     Int      @default(0)
  reorderLevel Int      @default(0)
  unitPrice    Decimal  @default(0) @db.Decimal(18, 2)
  description  String?
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category  ItemCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  expiryTracking ItemExpiryTracking[]
  wastageRecords WastageRecord[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([categoryId])
  @@index([quantity])
  @@index([status])
}

model StockMovement {
  id               String        @id @default(cuid())
  storeItemId      String
  type             MovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  referenceType    String?       // purchaseOrder, issuance, return, adjustment
  referenceId      String?
  issuedTo         String?       // department, staff, hostel, class
  conductedBy      String        // userId
  conductedAt      DateTime      @default(now())

  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([storeItemId])
  @@index([conductedAt])
  @@index([type])
  @@index([referenceId])
}

model Supplier {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  contracts      SupplierContract[]
  ratings        SupplierRating[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model PurchaseRequest {
  id          String              @id @default(cuid())
  storeId     String
  requestedBy String              // userId
  reason      String?
  status      PurchaseRequestStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  approvedBy  String?
  approvedAt  DateTime?

  items PurchaseRequestItem[]

  @@index([storeId])
  @@index([status])
}

model PurchaseRequestItem {
  id                String @id @default(cuid())
  purchaseRequestId String
  storeItemId       String
  quantityRequested Int
  estimatedUnitPrice Decimal? @db.Decimal(18, 2)

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model PurchaseOrder {
  id                String            @id @default(cuid())
  purchaseRequestId String?
  supplierId        String
  orderNumber       String            @unique // PO/YYYY/NNNN
  totalAmount       Decimal           @default(0) @db.Decimal(18, 2)
  status            PurchaseOrderStatus @default(DRAFT)
  orderedBy         String            // userId
  orderedAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]
  goodsReceived GoodsReceived[]

  @@index([supplierId])
  @@index([status])
  @@index([supplierId, status])
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  storeItemId     String
  quantity        Int
  unitPrice       Decimal @db.Decimal(18, 2)
  totalPrice      Decimal @db.Decimal(18, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  storeItem     StoreItem     @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model GoodsReceived {
  id              String   @id @default(cuid())
  purchaseOrderId String
  receivedBy      String   // userId
  receivedAt      DateTime @default(now())
  notes           String?

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items         GoodsReceivedItem[]

  @@index([purchaseOrderId])
}

model GoodsReceivedItem {
  id               String @id @default(cuid())
  goodsReceivedId  String
  storeItemId      String
  quantityReceived Int
  condition        String? // Good, Damaged, Expired

  goodsReceived GoodsReceived @relation(fields: [goodsReceivedId], references: [id], onDelete: Cascade)

  @@index([goodsReceivedId])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  DAMAGED
  EXPIRED
  RETURNED
}

enum PurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// ─── Phase 5: Fixed Asset Register ───────────────────────────────

model AssetCategory {
  id                        String              @id @default(cuid())
  schoolId                  String
  name                      String              // Furniture, ICT Equipment, Vehicles, Buildings, Lab Equipment
  code                      String?
  defaultUsefulLife         Int?                // years
  defaultDepreciationMethod DepreciationMethod?
  accountId                 String?             // default GL account for this category
  createdAt                 DateTime            @default(now())

  assets FixedAsset[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FixedAsset {
  id                 String             @id @default(cuid())
  schoolId           String
  assetNumber        String             @unique // AST/YYYY/NNNN
  name               String
  description        String?
  categoryId         String
  location           String?            // Building, Room, Department
  departmentId       String?
  serialNumber       String?
  model              String?
  manufacturer       String?
  purchaseDate       DateTime?
  purchasePrice      Decimal            @db.Decimal(18, 2)
  currentValue       Decimal            @db.Decimal(18, 2)
  usefulLifeYears    Int?
  salvageValue       Decimal            @default(0) @db.Decimal(18, 2)
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  condition          AssetCondition     @default(GOOD)
  status             AssetStatus        @default(ACTIVE)
  disposedAt         DateTime?
  disposalMethod     String?            // SOLD, DONATED, SCRAPPED, WRITTEN_OFF
  disposalAmount     Decimal?           @db.Decimal(18, 2)
  disposedBy         String?
  purchaseOrderId    String?            // link to PurchaseOrder
  accountId          String?            // link to Chart of Accounts
  photoUrl           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  category            AssetCategory       @relation(fields: [categoryId], references: [id])
  depreciationRecords AssetDepreciation[]
  maintenanceRecords  AssetMaintenance[]
  checkouts           AssetCheckout[]
  auditItems          AssetAuditItem[]
  insurance           AssetInsurance[]
  warranties          AssetWarranty[]

  @@index([schoolId])
  @@index([categoryId])
  @@index([status])
  @@index([departmentId])
  @@index([assetNumber])
}

model AssetDepreciation {
  id                 String   @id @default(cuid())
  fixedAssetId       String
  period             String   // "2025-Q1", "2024-2025"
  openingValue       Decimal  @db.Decimal(18, 2)
  depreciationAmount Decimal  @db.Decimal(18, 2)
  closingValue       Decimal  @db.Decimal(18, 2)
  calculatedAt       DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@unique([fixedAssetId, period])
  @@index([fixedAssetId])
}

model AssetMaintenance {
  id           String   @id @default(cuid())
  fixedAssetId String
  date         DateTime
  type         MaintenanceType
  description  String
  cost         Decimal? @db.Decimal(18, 2)
  performedBy  String?
  nextDueDate  DateTime?
  recordedBy   String   // userId
  createdAt    DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([date])
  @@index([nextDueDate])
}

enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
  NONE
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  UNSERVICEABLE
}

enum AssetStatus {
  ACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  WRITTEN_OFF
}

enum MaintenanceType {
  REPAIR
  SERVICE
  UPGRADE
  INSPECTION
}

// ─── Phase: Inter-Store Transfers ────────────────────────────────

model StoreTransfer {
  id              String         @id @default(cuid())
  schoolId        String
  transferNumber  String         @unique  // TRF/YYYY/NNNN
  fromStoreId     String
  toStoreId       String
  requestedBy     String
  approvedBy      String?
  status          TransferStatus @default(PENDING)
  reason          String?
  requestedAt     DateTime       @default(now())
  approvedAt      DateTime?
  completedAt     DateTime?

  items StoreTransferItem[]

  @@index([schoolId])
  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([status])
}

model StoreTransferItem {
  id              String @id @default(cuid())
  storeTransferId String
  storeItemId     String  // source store item
  targetItemId    String? // target store item (matched by name or manually mapped)
  quantity        Int
  receivedQty     Int?

  storeTransfer StoreTransfer @relation(fields: [storeTransferId], references: [id], onDelete: Cascade)

  @@index([storeTransferId])
}

enum TransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

// ─── Phase: Department Requisitions ─────────────────────────────

model Requisition {
  id                String            @id @default(cuid())
  schoolId          String
  requisitionNumber String            @unique  // REQ/YYYY/NNNN
  storeId           String
  department        String
  requestedBy       String
  approvedBy        String?
  status            RequisitionStatus @default(PENDING)
  purpose           String?
  requestedAt       DateTime          @default(now())
  approvedAt        DateTime?
  issuedAt          DateTime?
  issuedBy          String?

  items RequisitionItem[]

  @@index([schoolId])
  @@index([storeId])
  @@index([department])
  @@index([status])
}

model RequisitionItem {
  id                String @id @default(cuid())
  requisitionId     String
  storeItemId       String
  quantityRequested Int
  quantityIssued    Int?

  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

enum RequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIALLY_ISSUED
  ISSUED
  CANCELLED
}

// ─── Phase: Stock Takes & Reconciliation ────────────────────────

model StockTake {
  id            String          @id @default(cuid())
  schoolId      String
  storeId       String
  reference     String          @unique  // ST/YYYY/NNNN
  status        StockTakeStatus @default(PLANNED)
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  conductedBy   String?
  approvedBy    String?
  notes         String?
  createdAt     DateTime        @default(now())

  items StockTakeItem[]

  @@index([schoolId])
  @@index([storeId])
  @@index([status])
}

model StockTakeItem {
  id               String  @id @default(cuid())
  stockTakeId      String
  storeItemId      String
  itemName         String  // snapshot of item name at time of stock take
  systemQuantity   Int
  physicalQuantity Int?
  variance         Int?
  varianceReason   String?
  adjusted         Boolean @default(false)

  stockTake StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)

  @@index([stockTakeId])
}

enum StockTakeStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  APPROVED
  CANCELLED
}

// ─── Phase: Enhanced Supplier Management ────────────────────────

model SupplierContract {
  id             String   @id @default(cuid())
  supplierId     String
  contractNumber String?
  startDate      DateTime
  endDate        DateTime
  terms          String?
  value          Decimal? @db.Decimal(18, 2)
  status         Status   @default(ACTIVE)
  documentUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([endDate])
}

model SupplierRating {
  id              String   @id @default(cuid())
  supplierId      String
  purchaseOrderId String?
  deliveryScore   Int      // 1-5
  qualityScore    Int      // 1-5
  pricingScore    Int      // 1-5
  overallScore    Decimal  @db.Decimal(3, 1)
  comments        String?
  ratedBy         String
  ratedAt         DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

// ─── Phase: Expiry Tracking & Wastage ───────────────────────────

model ItemExpiryTracking {
  id          String   @id @default(cuid())
  storeItemId String
  batchNumber String?
  quantity    Int
  expiryDate  DateTime
  alertSent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([storeItemId])
  @@index([expiryDate])
}

model WastageRecord {
  id          String        @id @default(cuid())
  storeItemId String
  quantity    Int
  reason      WastageReason
  description String?
  recordedBy  String
  recordedAt  DateTime      @default(now())

  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([storeItemId])
  @@index([reason])
  @@index([recordedAt])
}

enum WastageReason {
  EXPIRED
  DAMAGED
  SPOILED
  OBSOLETE
  OTHER
}

// ─── Phase: Asset Lifecycle Enhancements ────────────────────────

model AssetCheckout {
  id             String         @id @default(cuid())
  fixedAssetId   String
  checkedOutTo   String         // staffId or department name
  checkedOutBy   String         // userId
  purpose        String?
  checkoutDate   DateTime       @default(now())
  expectedReturn DateTime?
  returnDate     DateTime?
  returnedBy     String?
  condition      AssetCondition?
  returnNotes    String?
  status         CheckoutStatus @default(CHECKED_OUT)

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([checkedOutTo])
  @@index([status])
  @@index([expectedReturn])
}

enum CheckoutStatus {
  CHECKED_OUT
  RETURNED
  OVERDUE
}

model AssetAudit {
  id            String          @id @default(cuid())
  schoolId      String
  reference     String          @unique  // AA/YYYY/NNNN
  scheduledDate DateTime?
  completedAt   DateTime?
  conductedBy   String?
  status        StockTakeStatus @default(PLANNED)  // reuse enum
  notes         String?
  createdAt     DateTime        @default(now())

  items AssetAuditItem[]

  @@index([schoolId])
  @@index([status])
}

model AssetAuditItem {
  id               String          @id @default(cuid())
  assetAuditId     String
  fixedAssetId     String
  found            Boolean?
  condition        AssetCondition?
  locationVerified Boolean?
  notes            String?

  assetAudit AssetAudit @relation(fields: [assetAuditId], references: [id], onDelete: Cascade)
  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([assetAuditId])
  @@index([fixedAssetId])
}

model AssetInsurance {
  id              String   @id @default(cuid())
  fixedAssetId    String
  provider        String
  policyNumber    String?
  coverageAmount  Decimal? @db.Decimal(18, 2)
  premium         Decimal? @db.Decimal(18, 2)
  startDate       DateTime
  endDate         DateTime
  status          Status   @default(ACTIVE)
  createdAt       DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([endDate])
}

model AssetWarranty {
  id           String   @id @default(cuid())
  fixedAssetId String
  provider     String
  warrantyType String?  // Manufacturer, Extended, Third-Party
  startDate    DateTime
  endDate      DateTime
  terms        String?
  createdAt    DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([endDate])
}
