model Store {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  managerId   String?  // staffId or userId
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items StoreItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ItemCategory {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  createdAt   DateTime @default(now())

  items StoreItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model StoreItem {
  id           String   @id @default(cuid())
  storeId      String
  categoryId   String?
  name         String
  code         String?
  unit         String   @default("pcs") // pcs, kg, liters, boxes, etc.
  quantity     Int      @default(0)
  reorderLevel Int      @default(0)
  unitPrice    Decimal  @default(0) @db.Decimal(18, 2)
  description  String?
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category  ItemCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([categoryId])
  @@index([quantity])
  @@index([status])
}

model StockMovement {
  id               String        @id @default(cuid())
  storeItemId      String
  type             MovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  referenceType    String?       // purchaseOrder, issuance, return, adjustment
  referenceId      String?
  issuedTo         String?       // department, staff, hostel, class
  conductedBy      String        // userId
  conductedAt      DateTime      @default(now())

  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([storeItemId])
  @@index([conductedAt])
  @@index([type])
  @@index([referenceId])
}

model Supplier {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model PurchaseRequest {
  id          String              @id @default(cuid())
  storeId     String
  requestedBy String              // userId
  reason      String?
  status      PurchaseRequestStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  approvedBy  String?
  approvedAt  DateTime?

  items PurchaseRequestItem[]

  @@index([storeId])
  @@index([status])
}

model PurchaseRequestItem {
  id                String @id @default(cuid())
  purchaseRequestId String
  storeItemId       String
  quantityRequested Int
  estimatedUnitPrice Decimal? @db.Decimal(18, 2)

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model PurchaseOrder {
  id                String            @id @default(cuid())
  purchaseRequestId String?
  supplierId        String
  orderNumber       String            @unique // PO/YYYY/NNNN
  totalAmount       Decimal           @default(0) @db.Decimal(18, 2)
  status            PurchaseOrderStatus @default(DRAFT)
  orderedBy         String            // userId
  orderedAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]
  goodsReceived GoodsReceived[]

  @@index([supplierId])
  @@index([status])
  @@index([supplierId, status])
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  storeItemId     String
  quantity        Int
  unitPrice       Decimal @db.Decimal(18, 2)
  totalPrice      Decimal @db.Decimal(18, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  storeItem     StoreItem     @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model GoodsReceived {
  id              String   @id @default(cuid())
  purchaseOrderId String
  receivedBy      String   // userId
  receivedAt      DateTime @default(now())
  notes           String?

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items         GoodsReceivedItem[]

  @@index([purchaseOrderId])
}

model GoodsReceivedItem {
  id               String @id @default(cuid())
  goodsReceivedId  String
  storeItemId      String
  quantityReceived Int
  condition        String? // Good, Damaged, Expired

  goodsReceived GoodsReceived @relation(fields: [goodsReceivedId], references: [id], onDelete: Cascade)

  @@index([goodsReceivedId])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  DAMAGED
  EXPIRED
  RETURNED
}

enum PurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// ─── Phase 5: Fixed Asset Register ───────────────────────────────

model AssetCategory {
  id                        String              @id @default(cuid())
  schoolId                  String
  name                      String              // Furniture, ICT Equipment, Vehicles, Buildings, Lab Equipment
  code                      String?
  defaultUsefulLife         Int?                // years
  defaultDepreciationMethod DepreciationMethod?
  accountId                 String?             // default GL account for this category
  createdAt                 DateTime            @default(now())

  assets FixedAsset[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FixedAsset {
  id                 String             @id @default(cuid())
  schoolId           String
  assetNumber        String             @unique // AST/YYYY/NNNN
  name               String
  description        String?
  categoryId         String
  location           String?            // Building, Room, Department
  departmentId       String?
  serialNumber       String?
  model              String?
  manufacturer       String?
  purchaseDate       DateTime?
  purchasePrice      Decimal            @db.Decimal(18, 2)
  currentValue       Decimal            @db.Decimal(18, 2)
  usefulLifeYears    Int?
  salvageValue       Decimal            @default(0) @db.Decimal(18, 2)
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  condition          AssetCondition     @default(GOOD)
  status             AssetStatus        @default(ACTIVE)
  disposedAt         DateTime?
  disposalMethod     String?            // SOLD, DONATED, SCRAPPED, WRITTEN_OFF
  disposalAmount     Decimal?           @db.Decimal(18, 2)
  disposedBy         String?
  purchaseOrderId    String?            // link to PurchaseOrder
  accountId          String?            // link to Chart of Accounts
  photoUrl           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  category            AssetCategory       @relation(fields: [categoryId], references: [id])
  depreciationRecords AssetDepreciation[]
  maintenanceRecords  AssetMaintenance[]

  @@index([schoolId])
  @@index([categoryId])
  @@index([status])
  @@index([departmentId])
  @@index([assetNumber])
}

model AssetDepreciation {
  id                 String   @id @default(cuid())
  fixedAssetId       String
  period             String   // "2025-Q1", "2024-2025"
  openingValue       Decimal  @db.Decimal(18, 2)
  depreciationAmount Decimal  @db.Decimal(18, 2)
  closingValue       Decimal  @db.Decimal(18, 2)
  calculatedAt       DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@unique([fixedAssetId, period])
  @@index([fixedAssetId])
}

model AssetMaintenance {
  id           String   @id @default(cuid())
  fixedAssetId String
  date         DateTime
  type         MaintenanceType
  description  String
  cost         Decimal? @db.Decimal(18, 2)
  performedBy  String?
  nextDueDate  DateTime?
  recordedBy   String   // userId
  createdAt    DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([date])
  @@index([nextDueDate])
}

enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
  NONE
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  UNSERVICEABLE
}

enum AssetStatus {
  ACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  WRITTEN_OFF
}

enum MaintenanceType {
  REPAIR
  SERVICE
  UPGRADE
  INSPECTION
}
