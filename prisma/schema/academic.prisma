model Class {
  id             String   @id @default(cuid())
  schoolId       String
  programmeId    String
  academicYearId String
  yearGroup      Int // 1, 2, or 3 for SHS
  name           String // e.g., "SHS 1 Science"
  code           String?
  maxCapacity    Int      @default(50)
  status         Status   @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  classArms     ClassArm[]
  examSchedules ExamSchedule[]

  @@unique([schoolId, name, academicYearId])
  @@index([schoolId])
  @@index([programmeId])
  @@index([academicYearId])
  @@index([yearGroup])
}

model ClassArm {
  id             String   @id @default(cuid())
  classId        String
  schoolId       String
  name           String // e.g., "A", "B", "1"
  capacity       Int      @default(50)
  classTeacherId String? // Staff ID of the class teacher
  status         Status   @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School       @relation("SchoolClassArm", fields: [schoolId], references: [id])
  enrollments Enrollment[]

  sourcePromotionRuns       PromotionRun[]     @relation("SourcePromotionArm")
  destinationPromotionItems PromotionRunItem[] @relation("DestinationPromotionArm")

  @@unique([classId, name])
  @@index([classId])
  @@index([schoolId])
}

model Enrollment {
  id                 String           @id @default(cuid())
  studentId          String
  classArmId         String
  schoolId           String
  academicYearId     String
  termId             String?
  enrollmentDate     DateTime         @default(now())
  status             EnrollmentStatus @default(ACTIVE)
  previousClassArmId String?
  /// Set by admissions when enrolling a verified CSSPS placement student.
  /// Billing logic should skip tuition line items when true; PTA/boarding fees still apply.
  /// TODO(finance): honour this flag in generateBillsAction once fee-item types are taxonomised.
  isFreeShsPlacement Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classArm ClassArm @relation(fields: [classArmId], references: [id], onDelete: Cascade)
  school   School   @relation("SchoolEnrollment", fields: [schoolId], references: [id])

  previousPromotionItems PromotionRunItem[] @relation("PreviousPromotionEnrollment")
  newPromotionItems      PromotionRunItem[] @relation("NewPromotionEnrollment")

  @@unique([studentId, academicYearId])
  @@index([studentId])
  @@index([classArmId])
  @@index([academicYearId])
  @@index([status])
  @@index([termId])
  @@index([schoolId])
}

enum EnrollmentStatus {
  ACTIVE
  TRANSFERRED
  WITHDRAWN
  PROMOTED
  COMPLETED
}

// ── Subjects & Assignments ──────────────────────────────

model Subject {
  id          String      @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  description String?
  type        SubjectType @default(CORE)
  status      Status      @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  programmeSubjects         ProgrammeSubject[]
  teacherSubjectAssignments TeacherSubjectAssignment[]
  marks                     Mark[]
  subjectResults            SubjectResult[]
  examSchedules             ExamSchedule[]
  subjectAnnualResults      SubjectAnnualResult[]
  studentSubjectSelections  StudentSubjectSelection[]
  academicAwards            AcademicAward[]
  homeworks                 Homework[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ProgrammeSubject {
  id          String  @id @default(cuid())
  programmeId String
  subjectId   String
  schoolId    String
  isCore      Boolean @default(true)
  yearGroup   Int? // null = all year groups

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school  School  @relation("SchoolProgrammeSubject", fields: [schoolId], references: [id])

  @@unique([programmeId, subjectId])
  @@index([programmeId])
  @@index([subjectId])
  @@index([schoolId])
}

model TeacherSubjectAssignment {
  id             String   @id @default(cuid())
  staffId        String // references User or Staff id
  subjectId      String
  classArmId     String
  schoolId       String
  academicYearId String
  termId         String?
  createdAt      DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school  School  @relation("SchoolTeacherSubjectAssignment", fields: [schoolId], references: [id])

  @@unique([staffId, subjectId, classArmId, academicYearId])
  @@index([staffId])
  @@index([subjectId])
  @@index([classArmId])
  @@index([academicYearId])
  @@index([termId])
  @@index([schoolId])
}

enum SubjectType {
  CORE
  ELECTIVE
}

// ── Assessments & Marks ─────────────────────────────────

model AssessmentType {
  id                 String             @id @default(cuid())
  schoolId           String
  name               String // e.g., "Class Test 1", "Mid-Term", "End of Term Exam"
  code               String?
  weight             Float              @default(0) // percentage weight toward term total
  maxScore           Float              @default(100)
  termId             String?
  category           AssessmentCategory @default(CLASSWORK)
  entryDeadline      DateTime?
  submissionDeadline DateTime?
  isLocked           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  marks Mark[]

  @@unique([schoolId, name, termId])
  @@index([schoolId])
  @@index([termId])
}

model Mark {
  id               String     @id @default(cuid())
  studentId        String
  subjectId        String
  assessmentTypeId String
  classArmId       String
  schoolId         String
  termId           String
  academicYearId   String
  score            Float
  maxScore         Float      @default(100)
  enteredBy        String // userId
  enteredAt        DateTime   @default(now())
  approvedBy       String?
  approvedAt       DateTime?
  status           MarkStatus @default(DRAFT)

  subject        Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  assessmentType AssessmentType @relation(fields: [assessmentTypeId], references: [id], onDelete: Cascade)
  school         School         @relation("SchoolMark", fields: [schoolId], references: [id])

  @@unique([studentId, subjectId, assessmentTypeId, termId])
  @@index([studentId])
  @@index([subjectId])
  @@index([classArmId])
  @@index([termId])
  @@index([assessmentTypeId])
  @@index([status])
  @@index([academicYearId])
  @@index([schoolId])
}

// ── Results & Report Cards ──────────────────────────────

model TerminalResult {
  id                String           @id @default(cuid())
  studentId         String
  classArmId        String
  schoolId          String
  termId            String
  academicYearId    String
  totalScore        Float?
  averageScore      Float?
  classPosition     Int?
  overallGrade      String?
  teacherRemarks    String?
  headmasterRemarks String?
  promotionStatus   PromotionStatus?
  computedAt        DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  subjectResults SubjectResult[]
  school         School          @relation("SchoolTerminalResult", fields: [schoolId], references: [id])

  @@unique([studentId, termId, academicYearId])
  @@index([studentId])
  @@index([classArmId])
  @@index([termId])
  @@index([academicYearId])
  @@index([classArmId, academicYearId])
  @@index([schoolId])
}

model SubjectResult {
  id               String  @id @default(cuid())
  terminalResultId String
  subjectId        String
  schoolId         String
  classScore       Float? // weighted CA total
  examScore        Float? // exam score
  totalScore       Float? // classScore + examScore
  grade            String?
  interpretation   String?
  position         Int?
  teacherInitials  String?
  caBreakdown      Json?

  terminalResult TerminalResult @relation(fields: [terminalResultId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school         School         @relation("SchoolSubjectResult", fields: [schoolId], references: [id])

  @@unique([terminalResultId, subjectId])
  @@index([terminalResultId])
  @@index([subjectId])
  @@index([schoolId])
}

enum AssessmentCategory {
  CLASSWORK
  HOMEWORK
  PROJECT
  MIDTERM
  END_OF_TERM
}

enum MarkStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PromotionStatus {
  PROMOTED
  RETAINED
  GRADUATED
  PENDING
}

// ─── Promotion Rules ────────────────────────────────────────────────

model PromotionRule {
  id                   String   @id @default(cuid())
  schoolId             String
  academicYearId       String?
  yearGroup            Int? // null = applies to all year groups
  passAverage          Float    @default(40)
  maxFailingSubjects   Int      @default(3)
  requireAttendance    Boolean  @default(false)
  minAttendancePercent Float?   @default(75)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([schoolId])
  @@index([academicYearId])
}

// ─── Transcripts ────────────────────────────────────────────────────

model Transcript {
  id               String    @id @default(cuid())
  schoolId         String
  studentId        String
  transcriptNumber String    @unique // TRN/YYYY/NNNN
  generatedBy      String // User ID
  generatedAt      DateTime  @default(now())
  coveringFrom     String? // e.g., "2022/2023"
  coveringTo       String? // e.g., "2024/2025"
  cumulativeGPA    Float?
  status           String    @default("GENERATED") // GENERATED, VERIFIED, ISSUED
  verifiedBy       String?
  verifiedAt       DateTime?
  notes            String?
  createdAt        DateTime  @default(now())

  @@index([schoolId])
  @@index([studentId])
}

// ─── Annual Results ────────────────────────────────────────────────

model AnnualResult {
  id              String           @id @default(cuid())
  studentId       String
  classArmId      String
  schoolId        String
  academicYearId  String
  totalScore      Float?
  averageScore    Float?
  classPosition   Int?
  overallGrade    String?
  subjectCount    Int?
  promotionStatus PromotionStatus?
  computedAt      DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  subjectAnnualResults SubjectAnnualResult[]
  school               School                @relation("SchoolAnnualResult", fields: [schoolId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([classArmId])
  @@index([academicYearId])
  @@index([classArmId, academicYearId])
  @@index([schoolId])
}

model SubjectAnnualResult {
  id             String  @id @default(cuid())
  annualResultId String
  subjectId      String
  schoolId       String
  term1Score     Float?
  term2Score     Float?
  term3Score     Float?
  averageScore   Float?
  grade          String?
  interpretation String?
  position       Int?

  annualResult AnnualResult @relation(fields: [annualResultId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school       School       @relation("SchoolSubjectAnnualResult", fields: [schoolId], references: [id])

  @@unique([annualResultId, subjectId])
  @@index([annualResultId])
  @@index([subjectId])
  @@index([schoolId])
}
